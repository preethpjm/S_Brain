		<xsd:sequence minOccurs="0">
			<xsd:element name="dcsnTmplId" type="decisionTreeTemplateIdentifier"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="decisionTreeTemplateActionDefinitionRef">
		<xsd:annotation>
			<xsd:documentation>
            DecisionTreeTemplateActionDefinition is a [class] that specifies actions and/or measures that must be taken as part of the decision process.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:DecisionTreeTemplateActionDefinition</source>
			</xsd:appinfo>
