					</xsd:sequence>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="vdtm" type="value:valueDeterminationCode" nillable="true" minOccurs="0"/>
			<xsd:choice>
				<xsd:sequence>
					<xsd:element name="unit" type="value:unit"/>
					<xsd:choice>
						<xsd:sequence>
