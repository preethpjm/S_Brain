	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="allowedProductOperationalRoleKitRef">
		<xsd:annotation>
			<xsd:documentation>
            AllowedProductOperationalRoleKit is a [relationship] that identifies a permitted combination of ProductOperationalKitItem and ProductOperationalRoleKit.
