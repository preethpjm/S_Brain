		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="degradationMechanismRelationshipRef">
		<xsd:annotation>
			<xsd:documentation>
            DegradationMechanismRelationship is a [relationship] where one DegradationMechanism relates to another DegradationMechanism.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:DegradationMechanismRelationship</source>
