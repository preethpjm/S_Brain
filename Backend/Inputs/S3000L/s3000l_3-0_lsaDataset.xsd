				<xsd:element name="beRevRef" type="breakdownElementRevisionRef"/>
				<xsd:element name="partRef" type="partDefinitionRef"/>
				<xsd:element name="prodRef" type="productRef"/>
				<xsd:element name="prodVarRef" type="productVariantRef"/>
