	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="baselineRelationshipRef">
		<xsd:annotation>
			<xsd:documentation>
            BaselineRelationship is a [relationship] where one Baseline relates to another Baseline.
         </xsd:documentation>
