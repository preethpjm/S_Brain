		<xsd:sequence minOccurs="0">
			<xsd:element name="dcsnTmplId" type="decisionTreeTemplateIdentifier"/>
			<xsd:element name="revId" type="decisionTreeTemplateRevisionIdentifier"/>
			<xsd:element name="actnId" type="decisionTreeTemplateActionDefinitionIdentifier"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="decisionTreeTemplateEndActionDefinitionRef">
		<xsd:annotation>
			<xsd:documentation>
            DecisionTreeTemplateEndActionDefinition is a DecisionTreeTemplateActionDefinition that defines an end action for the decision process.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:DecisionTreeTemplateEndActionDefinition</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="dcsnTmplId" type="decisionTreeTemplateIdentifier"/>
			<xsd:element name="revId" type="decisionTreeTemplateRevisionIdentifier"/>
			<xsd:element name="actnId" type="decisionTreeTemplateActionDefinitionIdentifier"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="decisionTreeTemplateFurtherAnalysisActionDefinitionRef">
		<xsd:annotation>
			<xsd:documentation>
            DecisionTreeTemplateFurtherAnalysisActionDefinition is a DecisionTreeTemplateActionDefinition that will be followed by another question or action.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:DecisionTreeTemplateFurtherAnalysisActionDefinition</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="dcsnTmplId" type="decisionTreeTemplateIdentifier"/>
			<xsd:element name="revId" type="decisionTreeTemplateRevisionIdentifier"/>
			<xsd:element name="actnId" type="decisionTreeTemplateActionDefinitionIdentifier"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="decisionTreeTemplateQuestionDefinitionRef">
		<xsd:annotation>
			<xsd:documentation>
            DecisionTreeTemplateQuestionDefinition is a [class] that specifies a question that result in a YES or NO answer.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:DecisionTreeTemplateQuestionDefinition</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="dcsnTmplId" type="decisionTreeTemplateIdentifier"/>
			<xsd:element name="revId" type="decisionTreeTemplateRevisionIdentifier"/>
			<xsd:element name="questId" type="decisionTreeTemplateQuestionDefinitionIdentifier"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="decisionTreeTemplateRevisionRef">
		<xsd:annotation>
			<xsd:documentation>
            DecisionTreeTemplateRevision is a [class] representing an iteration applied to a DecisionTreeTemplate.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:DecisionTreeTemplateRevision</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="dcsnTmplId" type="decisionTreeTemplateIdentifier"/>
			<xsd:element name="revId" type="decisionTreeTemplateRevisionIdentifier"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="degradationMechanismRef">
		<xsd:annotation>
			<xsd:documentation>
            DegradationMechanism is a class that represents a physical, chemical or other process that ultimately leads to a damage or failure.
         </xsd:documentation>
