	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="allowedProductOperationalRoleChangeRef">
		<xsd:annotation>
			<xsd:documentation>
            AllowedProductOperationalRoleChange is a [relationship] that defines a role change that is allowed for the product in one specific role to be configured 
