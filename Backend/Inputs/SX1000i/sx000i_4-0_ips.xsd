		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="globalPositionRef">
		<xsd:annotation>
			<xsd:documentation>
            GlobalPosition is a [class] that identifies a point in space by a set of coordinates.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:GlobalPosition</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="lat" type="latitude"/>
			<xsd:element name="long" type="longitude"/>
			<xsd:element name="alt" type="altitude"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:ID" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="hardwarePartDefinitionRef">
		<xsd:annotation>
			<xsd:documentation>
            HardwarePartDefinition is a PartDefinition that is to be realized as physical items, including non-countable material.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:HardwarePartDefinition</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="partId" type="partIdentifier"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:ID" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="infrastructureRef">
		<xsd:annotation>
			<xsd:documentation>
            Infrastructure is a [class] that represents basic physical and organizational structures and facilities which exists, or is intended to be built and is 
            needed for the operation of an organization or product or required for the provision of a service. 
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:Infrastructure</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="infrId" type="infrastructureIdentifier"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:ID" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="infrastructureAvailableRef">
		<xsd:annotation>
			<xsd:documentation>
            InfrastructureAvailable is a [relationship] that provides the capability of associating an infrastructure or facility to items that can use it.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:InfrastructureAvailable</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:choice>
				<xsd:element name="infrstrRef" type="infrastructureRef"/>
				<xsd:element name="infrRevRef" type="infrastructureRevisionRef"/>
			</xsd:choice>
			<xsd:element name="infrAvailRef" type="infrastructureAvailableRef"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:ID" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="infrastructureNodeRef">
		<xsd:annotation>
			<xsd:documentation>
            InfrastructureNode is a [class] that specifies an infrastructure node which is part of the defined Infrastructure.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:InfrastructureNode</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="infrId" type="infrastructureIdentifier"/>
			<xsd:element name="revId" type="infrastructureRevisionIdentifier"/>
			<xsd:element name="nodeId" type="infrastructureNodeIdentifier"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:ID" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="infrastructureNodeAtLocationRef">
		<xsd:annotation>
			<xsd:documentation>
            InfrastructureNodeAtLocation is a [relationship] that defines the location at which an IncludedInfrastructureNode is located.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:InfrastructureNodeAtLocation</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="infrNodeRef" type="infrastructureNodeRef"/>
			<xsd:element name="nodeAtLocRef" type="infrastructureNodeAtLocationRef"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:ID" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="infrastructureNodeRealizationRef">
		<xsd:annotation>
			<xsd:documentation>
            InfrastructureNodeRealization is a [relationship] where an InfrastructureNode relates to an instance of InfrastructureNodeItem which is used to realize the 
            InfrastructureNode.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:InfrastructureNodeRealization</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="infrNodeRef" type="infrastructureNodeRef"/>
			<xsd:element name="nodeRealRef" type="infrastructureNodeRealizationRef"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:ID" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="infrastructurePartyRef">
		<xsd:annotation>
			<xsd:documentation>
            InfrastructureParty is a [relationship] that identifies a Party that is associated with the Infrastructure.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:InfrastructureParty</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="infrstrRef" type="infrastructureRef"/>
			<xsd:element name="infrPtyRef" type="infrastructurePartyRef"/>
			<xsd:element name="ptyRole" type="infrastructurePartyRole"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:ID" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="infrastructureRelationshipRef">
		<xsd:annotation>
			<xsd:documentation>
            InfrastructureRelationship is a [relationship] where one Infrastructure relates to another Infrastructure.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:InfrastructureRelationship</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<!-- RELATING -->
			<xsd:element name="infrstrRef" type="infrastructureRef"/>
			<!-- RELATED -->
			<xsd:element name="infrRelRef" type="infrastructureRelationshipRef"/>
			<xsd:element name="relType" type="infrastructureRelationshipType"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:ID" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="infrastructureRevisionRef">
		<xsd:annotation>
			<xsd:documentation>
            InfrastructureRevision  is a [class] representing an iteration applied to an Infrastructure.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:InfrastructureRevision</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="infrId" type="infrastructureIdentifier"/>
			<xsd:element name="revId" type="infrastructureRevisionIdentifier"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:ID" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="instructionalStrategyRef">
		<xsd:annotation>
			<xsd:documentation>
            InstructionalStrategy is a [class] representing techniques used to support the acquisition of new knowledge, skills and attitudes.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:InstructionalStrategy</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="instrStrName" type="instructionalStrategyName"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:ID" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="instructionalStrategyRevisionRef">
		<xsd:annotation>
			<xsd:documentation>
            InstructionalStrategyRevision is a [class] representing an iteration applied to an instructional strategy.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:InstructionalStrategyRevision</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="instrStrName" type="instructionalStrategyName"/>
			<xsd:element name="revId" type="instructionalStrategyRevisionIdentifier"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:ID" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="iPSConceptRef">
		<xsd:annotation>
			<xsd:documentation>
            IPSConcept is a [class] representing the definition of an Integrated Product Support (IPS) concept.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:IPSConcept</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:attribute name="uidRef" type="xsd:ID" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="iPSConceptRelationshipRef">
		<xsd:annotation>
			<xsd:documentation>
            IPSConceptRelationship is a [relationship] that associates two different instances of IPSConcept.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:IPSConceptRelationship</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<!-- RELATING -->
			<xsd:element name="ipsConRef" type="iPSConceptRef"/>
			<!-- RELATED -->
			<xsd:element name="ipsConRelRef" type="iPSConceptRelationshipRef"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:ID" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="iPSConceptRevisionRef">
		<xsd:annotation>
			<xsd:documentation>
            IPSConceptRevision is a [class] representing an iteration applied to an IPSConcept.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:IPSConceptRevision</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:attribute name="uidRef" type="xsd:ID" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="iPSConceptRevisionRequirementRef">
		<xsd:annotation>
			<xsd:documentation>
            IPSConceptRevisionRequirement is a [relationship] that defines a Requirement that is required in order to enable an IPSConceptRevision.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:IPSConceptRevisionRequirement</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="ipsConRevRef" type="iPSConceptRevisionRef"/>
			<xsd:element name="ipsConRReqRef" type="iPSConceptRevisionRequirementRef"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:ID" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="iTArchitectureNodeRef">
		<xsd:annotation>
			<xsd:documentation>
            ITArchitectureNode is a [class] representing a functional or physical block in the information technology ITConceptRevision architecture.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:ITArchitectureNode</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:attribute name="uidRef" type="xsd:ID" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="iTArchitectureNodeRelationshipRef">
		<xsd:annotation>
			<xsd:documentation>
            ITArchitectureNodeRelationship is a [relationship] that associates two different instances of ITArchitectureNode.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:ITArchitectureNodeRelationship</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<!-- RELATING -->
			<xsd:element name="itArcNodeRef" type="iTArchitectureNodeRef"/>
			<!-- RELATED -->
			<xsd:element name="itArcRelRef" type="iTArchitectureNodeRelationshipRef"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:ID" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="iTConceptRevisionRef">
		<xsd:annotation>
			<xsd:documentation>
            ITConceptRevision is a [class] representing an iteration applied to the definition of an ITConcept.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:ITConceptRevision</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:attribute name="uidRef" type="xsd:ID" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="itemPlanningRef">
		<xsd:annotation>
			<xsd:documentation>
            ItemPlanning is a [class] that represents the planned schedule of an item.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:ItemPlanning</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:attribute name="uidRef" type="xsd:ID" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="itemUnderExportControlRegulationRef">
		<xsd:annotation>
			<xsd:documentation>
            ItemUnderExportControlRegulation is a [relationship] that allows to associate an ItemUnderExportControl with the ExportControlRegulation that governs its 
            export.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:ItemUnderExportControlRegulation</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:choice>
				<xsd:element name="docRef" type="documentRef"/>
				<xsd:element name="msgRef" type="messageRef"/>
				<xsd:element name="partRef" type="partDefinitionRef"/>
				<xsd:element name="serialPVRef" type="serializedProductVariantRef"/>
				<xsd:element name="swReleaseRef" type="softwarePartAsReleasedRef"/>
			</xsd:choice>
			<xsd:element name="assExpContrRef" type="itemUnderExportControlRegulationRef"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:ID" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="laborRatesRef">
		<xsd:annotation>
			<xsd:documentation>
            LaborRates is a [relationship] that assigns labor rates to different skills, skill levels and trades.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:LaborRates</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="contrClauseRef" type="contractClauseRef"/>
			<xsd:element name="labRatesRef" type="laborRatesRef"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:ID" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="locationDefinitionRef">
		<xsd:annotation>
			<xsd:documentation>
            LocationDefinition is a [class] that defines a particular place or position.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:LocationDefinition</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:attribute name="uidRef" type="xsd:ID" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="locationDefinitionRevisionRef">
		<xsd:annotation>
			<xsd:documentation>
            LocationDefinitionRevision is a [class] representing an iteration applied to a LocationDefinition.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:LocationDefinitionRevision</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:attribute name="uidRef" type="xsd:ID" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="locationRelationshipRef">
		<xsd:annotation>
			<xsd:documentation>
            LocationRelationship is a [relationship] where one LocationItem relates to another LocationItem
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:LocationRelationship</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:choice>
				<xsd:element name="countryRef" type="countryRef"/>
				<xsd:element name="geoAreaRef" type="geographicalAreaRef"/>
				<xsd:element name="globPosRef" type="globalPositionRef"/>
				<xsd:element name="strAddrRef" type="streetAddressRef"/>
			</xsd:choice>
			<xsd:element name="locRelRef" type="locationRelationshipRef"/>
			<xsd:element name="relType" type="locationRelationshipType"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:ID" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="logicalAndRef">
		<xsd:annotation>
			<xsd:documentation>
            LogicalAnd is an EvaluationCriteria that defines a boolean operation where the results of all its associated EvaluationCriteria must be TRUE for the result 
            to be TRUE, otherwise the result is FALSE.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:LogicalAnd</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:attribute name="uidRef" type="xsd:ID" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="logicalNotRef">
		<xsd:annotation>
			<xsd:documentation>
            LogicalNot is an EvaluationCriteria that defines a boolean operation where the result from its associated EvaluationCriteria must be FALSE for the result 
            to be TRUE, otherwise the result is FALSE.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:LogicalNot</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:attribute name="uidRef" type="xsd:ID" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="logicalOrRef">
		<xsd:annotation>
			<xsd:documentation>
            LogicalOr is an EvaluationCriteria that defines a boolean operation where the result from at least one of its associated EvaluationCriteria must be TRUE 
            for the result to be TRUE, otherwise the result is FALSE.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:LogicalOr</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:attribute name="uidRef" type="xsd:ID" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="logicalXorRef">
		<xsd:annotation>
			<xsd:documentation>
            LogicalXor is an EvaluationCriteria that defines a boolean operation where the result from one and only one of its associated EvaluationCriteria must be 
            TRUE for the result to be TRUE, otherwise the result is FALSE.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:LogicalXor</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:attribute name="uidRef" type="xsd:ID" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="maintenanceConceptRef">
		<xsd:annotation>
			<xsd:documentation>
            MaintenanceConcept is a specialized IPSConcept intended to describe how maintenance will be set up and performed as part of the overall support.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:MaintenanceConcept</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:attribute name="uidRef" type="xsd:ID" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="maintenanceConceptRevisionRef">
		<xsd:annotation>
			<xsd:documentation>
            MaintenanceConceptRevision is a [class] representing an iteration applied to a MaintenanceConcept.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:MaintenanceConceptRevision</source>
