		<xsd:annotation>
			<xsd:documentation>
            TransportNetwork is an Infrastructure used to transport items.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:TransportNetwork</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="infrId" type="infrastructureIdentifier"/>
