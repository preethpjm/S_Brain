			<xsd:element name="ptyAddr" type="partyAddress" nillable="true" minOccurs="0" maxOccurs="unbounded"/>
			<xsd:element name="ptyRel" type="partyRelationship" nillable="true" minOccurs="0" maxOccurs="unbounded"/>
		</xsd:sequence>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="performanceParameterItem">
		<xsd:annotation>
			<xsd:documentation>
            PerformanceParameterItem is an [extend] interface that provides its associated data model to those classes that can have an associated PerformanceParameter.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:PerformanceParameterItem</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence>
			<!-- UML-CompositionRelationships -->
			<xsd:element name="prfmPara" type="performanceParameter" nillable="true" minOccurs="0" maxOccurs="unbounded"/>
		</xsd:sequence>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="plannedItem">
		<xsd:annotation>
			<xsd:documentation>
            PlannedItem is a [extend] interface that represents an item for which a planning is made.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:PlannedItem</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence>
			<!-- UML-CompositionRelationships -->
			<xsd:element name="itemPlan" type="itemPlanning" nillable="true" minOccurs="0" maxOccurs="unbounded"/>
		</xsd:sequence>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="policyOrRegulationCompliantItem">
		<xsd:annotation>
			<xsd:documentation>
            PolicyOrRegulationCompliantItem is an [extend] interface that allows to associate an item with a PolicyOrRegulation with which it complies.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:PolicyOrRegulationCompliantItem</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence>
			<!-- UML-EmbeddedAssociations -->
			<xsd:element name="porCompl" type="compliancyPolicyOrRegulation" nillable="true" minOccurs="0" maxOccurs="unbounded"/>
		</xsd:sequence>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="productOperationalRoleItem">
		<xsd:annotation>
			<xsd:documentation>
            ProductOperationalRoleItem is an [extend] interface that provides its associated data model to those classes that can have an associated 
            ProductOperationalRole.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:ProductOperationalRoleItem</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence>
			<!-- UML-CompositionRelationships -->
			<xsd:element name="opRole" type="productOperationalRole" nillable="true" minOccurs="0" maxOccurs="unbounded"/>
		</xsd:sequence>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="productUsagePhaseItem">
		<xsd:annotation>
			<xsd:documentation>
            ProductUsagePhaseItem is an [extend] interface that provides its associated data model to those classes that implement it.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:ProductUsagePhaseItem</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence>
			<!-- UML-CompositionRelationships -->
			<xsd:element name="usePhse" type="productUsagePhase" nillable="true" minOccurs="0" maxOccurs="unbounded"/>
		</xsd:sequence>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="projectImpactedItem">
		<xsd:annotation>
			<xsd:documentation>
            ProjectImpactedItem is an [extend] document that enables the association of an item to the projects that affect it.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:ProjectImpactedItem</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence>
			<!-- UML-EmbeddedAssociations -->
			<xsd:element name="projImp" type="projectImpact" nillable="true" minOccurs="0" maxOccurs="unbounded"/>
		</xsd:sequence>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="projectSpecificExtensionItem">
		<xsd:annotation>
			<xsd:documentation>
            ProjectSpecificExtensionItem is an [extend] interface that allows to associate one or several instances of ProjectSpecificAttributes to any [class] or 
            [relationship] defined in the UML model.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:ProjectSpecificExtensionItem</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence>
			<!-- UML-CompositionRelationships -->
			<xsd:element name="projAttr" type="projectSpecificAttribute" nillable="true" minOccurs="0" maxOccurs="unbounded"/>
		</xsd:sequence>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="remarkItem">
		<xsd:annotation>
			<xsd:documentation>
            RemarkItem is an [extend] interface that provides its associated data model to those classes that implement it.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:RemarkItem</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence>
			<!-- UML-AttributeGroups -->
			<xsd:element name="rmk" type="remark" nillable="true" minOccurs="0" maxOccurs="unbounded"/>
		</xsd:sequence>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="reportedMetricItem">
		<xsd:annotation>
			<xsd:documentation>
            ReportedMetricItem is an [extend] interface that provides its associated data model to those classes that can have an associated ReportedMetric.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:ReportedMetricItem</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence>
			<!-- UML-CompositionRelationships -->
			<xsd:element name="rptdMetr" type="reportedMetric" nillable="true" minOccurs="0" maxOccurs="unbounded"/>
		</xsd:sequence>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="resourceSpecificationComplianceItem">
		<xsd:annotation>
			<xsd:documentation>
            ResourceSpecificationComplianceItem is an [extend] interface that provides its associated data model to those classes that implement it.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:ResourceSpecificationComplianceItem</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence>
			<!-- UML-EmbeddedAssociations -->
			<xsd:element name="specCompl" type="resourceSpecificationCompliance" nillable="true" minOccurs="0" maxOccurs="unbounded"/>
		</xsd:sequence>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="restrictionItem">
		<xsd:annotation>
			<xsd:documentation>
            RestrictionItem is a [select] interface representing classes that can have one or more instances of Restriction being associated with them.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:RestrictionItem</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence>
			<!-- UML-CompositionRelationships -->
			<xsd:element name="restr" type="restriction" nillable="true" minOccurs="0" maxOccurs="unbounded"/>
		</xsd:sequence>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="riskContextItem">
		<xsd:annotation>
			<xsd:documentation>
            RiskContextItem is an [extend] interface that enables the definition of the context in which a Risk is identified.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:RiskContextItem</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence>
			<!-- UML-CompositionRelationships -->
			<xsd:element name="risk" type="risk" nillable="true" minOccurs="0" maxOccurs="unbounded"/>
		</xsd:sequence>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="securityClassificationItem">
		<xsd:annotation>
			<xsd:documentation>
            SecurityClassificationItem is an [extend] interface that provides its associated data model to those classes that implement it.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:SecurityClassificationItem</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence>
			<!-- UML-EmbeddedAssociations -->
			<xsd:element name="sec" type="securityClassification" nillable="true" minOccurs="0" maxOccurs="unbounded"/>
		</xsd:sequence>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="staffingItem">
		<xsd:annotation>
			<xsd:documentation>
            StaffingItem is an [extend] interface that represents all items that can have staff associated to them.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:StaffingItem</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence>
			<!-- UML-EmbeddedAssociations -->
			<xsd:element name="staffBy" type="staffedBy" nillable="true" minOccurs="0" maxOccurs="unbounded"/>
		</xsd:sequence>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="supplySource">
		<xsd:annotation>
			<xsd:documentation>
            SupplySource is an [extend]interface that enables the definition of the management or items requiring supplies by the provisioning sources that can 
            actually perform the physical supply.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:SupplySource</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence>
			<!-- UML-EmbeddedAssociations -->
			<xsd:element name="suppProv" type="supplyProvision" nillable="true" minOccurs="0" maxOccurs="unbounded"/>
			<xsd:element name="suppSrcMng" type="supplySourceManagement" nillable="true" minOccurs="0" maxOccurs="unbounded"/>
		</xsd:sequence>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="timeOffsetItem">
		<xsd:annotation>
			<xsd:documentation>
            TimeOffsetItem is an [extend] interface that provides its associated data model to those classes that implement it.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:TimeOffsetItem</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence>
			<!-- UML-AttributeGroups -->
			<xsd:element name="offset" type="timeOffset" nillable="true" minOccurs="0"/>
		</xsd:sequence>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="workBreakdownContext">
		<xsd:annotation>
			<xsd:documentation>
            WorkBreakdownContext  is an [extend] interface that provides its associated data model to those classes that can have an associated WorkBreakdown.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:WorkBreakdownContext</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence>
			<!-- UML-CompositionRelationships -->
			<xsd:element name="wbs" type="workBreakdown" nillable="true" minOccurs="0" maxOccurs="unbounded"/>
		</xsd:sequence>
	</xsd:complexType>
	<!-- ============================== UML SPECIALIZATION UTILITY CLASSES ================================== -->
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:group name="areaNonAbstractClasses">
		<xsd:annotation>
			<xsd:documentation>
            Area is a specialization of Dimensions that represents the extent or measurement of a two-dimensional surface.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:Area</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:choice>
			<xsd:element name="circle" type="circle"/>
			<xsd:element name="rect" type="rectangle"/>
			<xsd:element name="triangle" type="triangle"/>
		</xsd:choice>
	</xsd:group>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:group name="contractClauseNonAbstractClasses">
		<xsd:annotation>
			<xsd:documentation>
            ContractClause is a class that represents specific provision included in a Contract.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:ContractClause</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:choice>
			<xsd:element name="contrClause" type="contractClause"/>
			<xsd:element name="slaClause" type="serviceLevelAgreementClause"/>
		</xsd:choice>
	</xsd:group>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:group name="dimensionsNonAbstractClasses">
		<xsd:annotation>
			<xsd:documentation>
            Dimensions is a [compoundAttribute] that represents a set of values that define the measurable extent of a particular kind for a specific item.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:Dimensions</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:choice>
			<xsd:group ref="areaNonAbstractClasses"/>
			<xsd:group ref="threeDimensionalNonAbstractClasses"/>
		</xsd:choice>
	</xsd:group>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:group name="documentNonAbstractClasses">
		<xsd:annotation>
			<xsd:documentation>
            Document is a [class] that represents a compiled set of information that serves a purpose. 
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:Document</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:choice>
			<xsd:element name="doc" type="document"/>
			<xsd:element name="expContrReg" type="exportControlRegulation"/>
			<xsd:element name="polOrReg" type="policyOrRegulation"/>
			<xsd:element name="rpt" type="report"/>
			<xsd:element name="s1000dDM" type="s1000DDataModule"/>
			<xsd:element name="s1000dPM" type="s1000DPublicationModule"/>
		</xsd:choice>
	</xsd:group>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:group name="evaluationCriteriaNonAbstractClasses">
		<xsd:annotation>
			<xsd:documentation>
            EvaluationCriteria is a [class] that defines conditions that can be mapped to a Boolean expression which can be evaluated to be either TRUE or FALSE.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:EvaluationCriteria</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:choice>
			<xsd:element name="assrtInst" type="evaluationByAssertionOfClassInstance"/>
			<xsd:element name="assrtCond" type="evaluationByAssertionOfCondition"/>
			<xsd:element name="assrtPeriod" type="evaluationByAssertionOfDateRange"/>
			<xsd:element name="assrtSi" type="evaluationByAssertionOfSerializedItems"/>
			<xsd:element name="nestedApplic" type="evaluationByNestedApplicabilityStatement"/>
			<xsd:element name="evalAnd" type="logicalAnd"/>
			<xsd:element name="evalNot" type="logicalNot"/>
			<xsd:element name="evalOr" type="logicalOr"/>
			<xsd:element name="evalXor" type="logicalXor"/>
		</xsd:choice>
	</xsd:group>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:group name="facilityNonAbstractClasses">
		<xsd:annotation>
			<xsd:documentation>
            Facility is a [class]that represents a physically limited infrastructure which exists, or is intended to be built or installed, and is established to serve 
            a particular purpose.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:Facility</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:choice>
			<xsd:element name="facility" type="facility"/>
			<xsd:element name="opBase" type="operatingBase"/>
			<xsd:element name="oFac" type="otherFacility"/>
			<xsd:element name="trainFac" type="trainingFacility"/>
		</xsd:choice>
	</xsd:group>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:group name="infrastructureNonAbstractClasses">
		<xsd:annotation>
			<xsd:documentation>
            Infrastructure is a [class] that represents basic physical and organizational structures and facilities which exists, or is intended to be built and is 
            needed for the operation of an organization or product or required for the provision of a service. 
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:Infrastructure</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:choice>
			<xsd:element name="infrstr" type="infrastructure"/>
			<xsd:element name="cloud" type="cloudInfrastructure"/>
			<xsd:element name="commNet" type="communicationsNetwork"/>
			<xsd:element name="compNet" type="computerNetwork"/>
			<xsd:element name="mroNet" type="mRONetwork"/>
			<xsd:element name="pwrGrid" type="powerGrid"/>
			<xsd:element name="trpNet" type="transportNetwork"/>
		</xsd:choice>
	</xsd:group>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:group name="iPSConceptNonAbstractClasses">
		<xsd:annotation>
			<xsd:documentation>
            IPSConcept is a [class] representing the definition of an Integrated Product Support (IPS) concept.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:IPSConcept</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:choice>
			<xsd:element name="ipsCon" type="iPSConcept"/>
			<xsd:element name="maintCon" type="maintenanceConcept"/>
			<xsd:element name="opCon" type="operationalConcept"/>
			<xsd:element name="provCon" type="provisioningConcept"/>
			<xsd:element name="trainCon" type="trainingConcept"/>
		</xsd:choice>
	</xsd:group>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:group name="iPSConceptRevisionNonAbstractClasses">
		<xsd:annotation>
			<xsd:documentation>
            IPSConceptRevision is a [class] representing an iteration applied to an IPSConcept.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:IPSConceptRevision</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:choice>
			<xsd:element name="ipsConRev" type="iPSConceptRevision"/>
			<xsd:element name="itConRev" type="iTConceptRevision"/>
			<xsd:element name="maintConRev" type="maintenanceConceptRevision"/>
			<xsd:element name="opConRev" type="operationalConceptRevision"/>
			<xsd:element name="provConRev" type="provisioningConceptRevision"/>
			<xsd:element name="trainConRev" type="trainingConceptRevision"/>
		</xsd:choice>
	</xsd:group>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:group name="numericalPropertyTypeNonAbstractClasses">
		<xsd:annotation>
			<xsd:documentation>
            NumericalPropertyType is a PropertyType that represents a quantity by its numerical value together with the unit in which the value is given.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:NumericalPropertyType</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:choice>
			<xsd:element name="valuePrpType" type="singleValuePropertyType"/>
			<xsd:element name="rangePrpType" type="valueRangePropertyType"/>
			<xsd:element name="tolcePrpType" type="valueWithTolerancesPropertyType"/>
		</xsd:choice>
	</xsd:group>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:group name="organizationNonAbstractClasses">
		<xsd:annotation>
			<xsd:documentation>
            Organization is a [class] that represents an administrative structure with a particular purpose belonging to a legal entity.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:Organization</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:choice>
			<xsd:element name="org" type="organization"/>
			<xsd:element name="operOrg" type="operatorOrganization"/>
		</xsd:choice>
	</xsd:group>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:group name="partDefinitionNonAbstractClasses">
		<xsd:annotation>
			<xsd:documentation>
            PartDefinition is a [class] that represents the definitional information for an artifact fulfilling a set of requirements, which can be produced or 
            realized.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:PartDefinition</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:choice>
			<xsd:element name="hwPart" type="hardwarePartDefinition"/>
		</xsd:choice>
	</xsd:group>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:group name="policyOrRegulationNonAbstractClasses">
		<xsd:annotation>
			<xsd:documentation>
            PolicyOrRegulation is a Document that defines mandatory practices for an item requiring specific guidelines.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:PolicyOrRegulation</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:choice>
			<xsd:element name="polOrReg" type="policyOrRegulation"/>
			<xsd:element name="expContrReg" type="exportControlRegulation"/>
		</xsd:choice>
	</xsd:group>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:group name="propertyTypeNonAbstractClasses">
		<xsd:annotation>
			<xsd:documentation>
            PropertyType is an S-Series IPS specifications defined [primitive] that represents a measurable characteristic.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:PropertyType</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:choice>
			<xsd:group ref="numericalPropertyTypeNonAbstractClasses"/>
			<xsd:element name="txtPrpType" type="textPropertyType"/>
		</xsd:choice>
	</xsd:group>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:group name="requirementNonAbstractClasses">
		<xsd:annotation>
			<xsd:documentation>
            Requirement is a documented need that must be implemented.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:Requirement</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:choice>
			<xsd:element name="req" type="requirement"/>
			<xsd:element name="ctrReq" type="contractRequirement"/>
		</xsd:choice>
	</xsd:group>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:group name="threeDimensionalNonAbstractClasses">
		<xsd:annotation>
			<xsd:documentation>
            ThreeDimensional is a specialization of Dimensions that represents three dimensional spatial magnitudes.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:ThreeDimensional</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:choice>
			<xsd:element name="cuboid" type="cuboid"/>
			<xsd:element name="cylinder" type="cylinder"/>
			<xsd:element name="sphere" type="sphere"/>
		</xsd:choice>
	</xsd:group>
	<!-- ===================================== BASE SCHEMA DEFINITIONS ====================================== -->
	<xsd:simpleType name="uidRef">
		<xsd:restriction base="xsd:IDREF"/>
	</xsd:simpleType>
	<xsd:simpleType name="nonEmptyString">
		<xsd:restriction base="xsd:token">
			<xsd:minLength value="1"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="crudCode">
		<xsd:restriction base="xsd:string">
			<xsd:enumeration value="I">
				<xsd:annotation>
					<xsd:appinfo>
						<source>SX001G:insertedElement</source>
					</xsd:appinfo>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="D">
				<xsd:annotation>
					<xsd:appinfo>
						<source>SX001G:deletedElement</source>
					</xsd:appinfo>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="U">
				<xsd:annotation>
					<xsd:appinfo>
						<source>SX001G:updatedElement</source>
					</xsd:appinfo>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="R">
				<xsd:annotation>
					<xsd:appinfo>
						<source>SX001G:replacedElement</source>
					</xsd:appinfo>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="N">
				<xsd:annotation>
					<xsd:appinfo>
						<source>SX001G:nonChangedElement</source>
					</xsd:appinfo>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
</xsd:schema>