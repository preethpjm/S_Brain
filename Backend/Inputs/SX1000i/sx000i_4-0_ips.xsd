		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="supportedProductCapabilityRef">
		<xsd:annotation>
			<xsd:documentation>
            SupportedProductCapability is a [relationship] that identifies a capability defined for the product, which the product operational role is designed to 
            support.
