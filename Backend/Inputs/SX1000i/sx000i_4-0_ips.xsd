		<xsd:attribute name="uidRef" type="xsd:ID" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="meetingRef">
		<xsd:annotation>
			<xsd:documentation>
            Meeting is a class representing a formal encounter taking place to address a common purpose.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:Meeting</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:attribute name="uidRef" type="xsd:ID" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="meetingAgreementRef">
		<xsd:annotation>
			<xsd:documentation>
            MeetingAgreement is a formal decision taken during a Meeting.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:MeetingAgreement</source>
			</xsd:appinfo>
