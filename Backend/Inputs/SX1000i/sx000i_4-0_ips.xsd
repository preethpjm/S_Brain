	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="missionDefinitionRevisionLocationRef">
		<xsd:annotation>
			<xsd:documentation>
            MissionDefinitionRevisionLocation is a [relationship] allowing to associate a MissionDefinitionRevision to teh location when it is performed.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:MissionDefinitionRevisionLocation</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="missnDRevRef" type="missionDefinitionRevisionRef"/>
			<xsd:element name="missnDRLocRef" type="missionDefinitionRevisionLocationRef"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:ID" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="mRONetworkRef">
		<xsd:annotation>
			<xsd:documentation>
            MRONetwork is an Infrastructure consisting or Maintenance, Repair and Overhaul (MRO) facilities.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:MRONetwork</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="infrId" type="infrastructureIdentifier"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:ID" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="necessaryInfrastructureRef">
		<xsd:annotation>
			<xsd:documentation>
            NecessaryInfrastructure is a [relationship] that defines the infrastructure that is required to fulfill a specific Requirement.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:NecessaryInfrastructure</source>
			</xsd:appinfo>
		</xsd:annotation>
