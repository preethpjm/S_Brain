	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="staffedByRef">
		<xsd:annotation>
			<xsd:documentation>
            StaffedBy is a [relationship] that defines the current or expected number of persons of a specific profile (TypeOfPerson) working on an entity during a 
