	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="operatingBaseRef">
		<xsd:annotation>
			<xsd:documentation>
            OperatingBase is a permanent or semi-permanent Facility that is mainly established for providing support for operations.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:OperatingBase</source>
			</xsd:appinfo>
