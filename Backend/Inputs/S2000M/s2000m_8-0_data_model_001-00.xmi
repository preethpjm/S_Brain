mlRefName"/><Column name="Value" value="specAvailRef"/><Column name="ea_guid" value="{5D8AEC4F-224C-4181-9352-F5A0A967FACA}"/><Extension Object_ID="{10FF9EE9-2CC0-41db-A56D-0A06CF3861FF}"/></Row><Row><Column name="PropertyID" value="1902"/><Column name="Object_ID" value="1640"/><Column name="Property" value="uidPattern"/><Column name="Value" value="specavail"/><Column name="ea_guid" value="{95DBE7C2-B4CF-4555-9795-85DCFFF48BB0}"/><Extension Object_ID="{10FF9EE9-2CC0-41db-A56D-0A06CF3861FF}"/></Row><Row><Column name="PropertyID" value="1904"/><Column name="Object_ID" value="1639"/><Column name="Property" value="uidPattern"/><Column name="Value" value="stdavail"/><Column name="ea_guid" value="{7BB3D805-5C8B-4ec2-B3C2-6351EF9B3D59}"/><Extension Object_ID="{C4A5D673-3BD3-470c-9F61-5F02699171DA}"/></Row><Row><Column name="PropertyID" value="1905"/><Column name="Object_ID" value="1645"/><Column name="Property" value="xmlName"/><Column name="Value" value="timeRange"/><Column name="ea_guid" value="{2DBBBAA4-331C-4668-A061-A8B8450FE4BB}"/><Extension Object_ID="{85D7A8CD-4672-4650-A799-38AD62CEDD2E}"/></Row><Row><Column name="PropertyID" value="1906"/><Column name="Object_ID" value="300"/><Column name="Property" value="replaces"/><Column name="Value" value="LogicalAND"/><Column name="ea_guid" value="{8F5889D5-EFB2-40ca-A6B9-EA2D230C8C12}"/><Extension Object_ID="{474AE1D1-E6CB-4caf-B7A4-750B9B918B89}"/></Row><Row><Column name="PropertyID" value="1907"/><Column name="Object_ID" value="303"/><Column name="Property" value="replaces"/><Column name="Value" value="LogicalNOT"/><Column name="ea_guid" value="{41403904-1125-4ac4-A871-B9244126EA8D}"/><Extension Object_ID="{5C3D7309-0331-48c3-A119-DAA108192C57}"/></Row><Row><Column name="PropertyID" value="1908"/><Column name="Object_ID" value="301"/><Column name="Property" value="replaces"/><Column name="Value" value="LogicalOR"/><Column name="ea_guid" value="{A8FC371E-B0E7-4bd0-BBA6-E4760FD3DA30}"/><Extension Object_ID="{8CC680C0-0A66-48ee-9761-E276E923178D}"/></Row><Row><Column name="PropertyID" value="1999"/><Column name="Object_ID" value="400"/><Column name="Property" value="longDescription"/><Column name="Notes" value="Key features of the UoF message data model ([referTo/]) are:[randomList]&#xA;[li]MessageContext provides the context within which the Message is defined[/li]&#xA;[li]MessageContent must be specialized in order to represent the collection of information that is the subject for the Message[/li]&#xA;[li]MessageParty which identifies its stakeholders, eg, sender and receiver[/li][/randomList]"/><Column name="ea_guid" value="{C5B05D55-1031-4083-A37E-C51EB7F5E4A8}"/><Extension Object_ID="{EF8ADF27-377F-4b75-A1EE-A876237A4E9A}"/></Row><Row><Column name="PropertyID" value="2002"/><Column name="Object_ID" value="401"/><Column name="Property" value="longDescription"/><Column name="Notes" value="[referTo/]"/><Column name="ea_guid" value="{4F777E25-BA03-4096-8D49-70C613D4A684}"/><Extension Object_ID="{30707D55-F184-4be9-A1E2-5BCACB0DE47D}"/></Row><Row><Column name="PropertyID" value="2005"/><Column name="Object_ID" value="531"/><Column name="Property" value="longDescription"/><Column name="Notes" value="A key feature of the UoF Part As Realized data model ([referTo/]) is that a part as realized is defined as either SerializedHardwarePart, BatchHardwarePart or SoftwarePartAsRealized."/><Column name="ea_guid" value="{40BC5BAC-DC69-4d68-BA7B-6A470FE08C1A}"/><Extension Object_ID="{4919673C-DDE5-4c3d-82E8-8FFEF4D91B75}"/></Row><Row><Column name="PropertyID" value="2006"/><Column name="Object_ID" value="406"/><Column name="Property" value="longDescription"/><Column name="Notes" value="Key features of the UoF Part Definition data model ([referTo/]) are:[randomList]&#xA;[li]A PartDefinition represents the definitional information for an artifact fulfilling a set of requirements, which can be produced or realized[/li]&#xA;[li]A PartDefinition must be defined as either a HardwarePartDefinition or a SoftwarePartDefinition[/li]&#xA;[li]A PartDefinition can have one or more alternate instances of PartDefinition. An alternate PartDefinition is interchangeable with the base PartDefinition in all its usages[/li]&#xA;[li]A PartDefinition can have one or many Bill-Of-Materials (BOM) using the PartDefinitionPartsList class; in other words, a PartDefinition can consist of other PartDefinition[/li]&#xA;[li]An entry in a PartDefinitionPartsList can have one or many substitute parts[/li]&#xA;[li]A substitute part is only valid in the context of its usage within the specified PartDefinitionPartsListRevision.[/li]&#xA;[li]A HardwarePartDefinition can contain substances. Instances of SubstanceDefinition are defined separately and are then associated with the HardwarePartDefinition in which they are being contained[/li][/randomList]"/><Column name="ea_guid" value="{31DF7308-743E-45ee-A1D6-6E08A04E88BF}"/><Extension Object_ID="{1561FC88-124E-4a19-A6BC-05D5E594CE83}"/></Row><Row><Column name="PropertyID" value="2012"/><Column name="Object_ID" value="398"/><Column name="Property" value="longDescription"/><Column name="Notes" value="[referTo/]"/><Column name="ea_guid" value="{E9F6E856-FB56-470e-AB92-28DD635A525F}"/><Extension Object_ID="{52A717D3-E3B7-4fa0-8CD4-41DD95548AF6}"/></Row><Row><Column name="PropertyID" value="2017"/><Column name="Object_ID" value="716"/><Column name="Property" value="longDescription"/><Column name="Notes" value="[referTo/]"/><Column name="ea_guid" value="{F6BC5857-C8C7-4780-8E05-0955FD62BB66}"/><Extension Object_ID="{9B341C28-F22B-4b8d-9110-0B0F485F3440}"/></Row><Row><Column name="PropertyID" value="2019"/><Column name="Object_ID" value="1571"/><Column name="Property" value="longDescription"/><Column name="Notes" value="[referTo/]"/><Column name="ea_guid" value="{FC53E122-9280-4f8b-8D11-28EFB8242273}"/><Extension Object_ID="{2ED85FCC-0A09-4fee-AB4A-D393F73E4551}"/></Row><Row><Column name="PropertyID" value="2020"/><Column name="Object_ID" value="1621"/><Column name="Property" value="longDescription"/><Column name="Notes" value="A key feature of the UoF Project Specific Attribute data model ([referTo/]) is that project-specific attributes can be added onto any member of ProjectSpecificExtensionItem and can be of any type that implements ProjectSepcificAttributeValue.&#xA;[note]The decision to use a given project-specific attribute must be made during the specification-tailoring phase of a project. A Business Rule Decision Point typically prompts that decision.[/note]"/><Column name="ea_guid" value="{6266B00C-E53C-473a-9550-D3A8335C556C}"/><Extension Object_ID="{8860E784-C2AE-49a6-83DE-A58D57E2FE93}"/></Row><Row><Column name="PropertyID" value="2021"/><Column name="Object_ID" value="399"/><Column name="Property" value="longDescription"/><Column name="Notes" value="A key feature of the UoF Remark data model ([referTo/]) is that a Remark can be associated with any class instance as well as with any individual attribute value."/><Column name="ea_guid" value="{DF446FB0-8FB8-4e6a-9E97-1B01591E84A2}"/><Extension Object_ID="{CA447961-C44A-45aa-A4E8-C69A2D1BD1EE}"/></Row><Row><Column name="PropertyID" value="2029"/><Column name="Object_ID" value="407"/><Column name="Property" value="longDescription"/><Column name="Notes" value="[referTo/]"/><Column name="ea_guid" value="{BAE25DC0-0777-4850-B856-AA0E7B9161C6}"/><Extension Object_ID="{2C6F1CC0-DBDE-4c1c-9E0B-ECF61820F939}"/></Row><Row><Column name="PropertyID" value="2031"/><Column name="Object_ID" value="546"/><Column name="Property" value="longDescription"/><Column name="Notes" value="[referTo/]"/><Column name="ea_guid" value="{0824E7B8-3789-4a2d-8200-29CD7153816C}"/><Extension Object_ID="{B34369AF-54BB-4870-B253-338DAA09C9EB}"/></Row><Row><Column name="PropertyID" value="2044"/><Column name="Object_ID" value="32"/><Column name="Property" value="longDescription"/><Column name="Value" value="ClassificationType Primitive"/><Column name="Notes" value="[referTo/]."/><Column name="ea_guid" value="{BDE9F75C-6B81-4697-A713-FBBB10AF0B03}"/><Extension Object_ID="{6A86C9A5-5B4D-46eb-B991-48A68729948A}"/></Row><Row><Column name="PropertyID" value="2045"/><Column name="Object_ID" value="32"/><Column name="Property" value="longDescription"/><Column name="Value" value="DescriptorType Primitive"/><Column name="Notes" value="DescriptorType is an S-Series IPS specifications defined &lt;&lt;primitive&gt;&gt; that represents any form of textual data (free form) along with its core characterizations. [referTo/].&#xA;Core characterizations for the DescriptorType descriptorText attribute include:[randomList]&#xA;[li]descriptorLanguage, that determines the language in which the descriptorText is written[/li]&#xA;[li]descriptorProvidedBy, which identifies the organization that provided the descriptorText[/li]&#xA;[li]descriptorProvidedDate, which defines when the descriptorText was provided[/li][/randomList]"/><Column name="ea_guid" value="{2629BFEA-F4FE-4f3d-A0BA-1DE6D349843A}"/><Extension Object_ID="{6A86C9A5-5B4D-46eb-B991-48A68729948A}"/></Row><Row><Column name="PropertyID" value="2046"/><Column name="Object_ID" value="32"/><Column name="Property" value="longDescription"/><Column name="Value" value="NameType Primitive"/><Column name="Notes" value="Core characterizations for the NameType nameText attribute include:[randomList]&#xA;[li]nameLanguage, that determines the language in which the nameText is written[/li]&#xA;[li]nameProvidedBy, which identifies the Organization that defined the nameText[/li][/randomList]&#xA;"/><Column name="ea_guid" value="{82C77C55-E533-4035-AECF-C09ECFDA0402}"/><Extension Object_ID="{6A86C9A5-5B4D-46eb-B991-48A68729948A}"/></Row><Row><Column name="PropertyID" value="2048"/><Column name="Object_ID" value="32"/><Column name="Property" value="longDescription"/><Column name="Value" value="PropertyType Primitive"/><Column name="Notes" value="There are four different specializations of PropertyType, which can be used to represent an individual property value ([referTo/]). These are:[randomList]&#xA;[li]SingleValuePropertyType, which is a NumericalPropertyType that specifies a single value and its unit[/li]&#xA;[li]ValueWithTolerancesPropertyType, which is a NumericalPropertyType that specifies a range of values by specifying a single nominalValue and its unit together with the permitted variations from the nominal value[/li]&#xA;[li]ValueRangePropertyType, which is a NumericalPropertyType that specifies a value pair that represents the range limits and their unit[/li]&#xA;[li]TextPropertyType, which is a PropertyType that specifies the value in text format[note]Text values are typically used to represent values such as &quot;AsRequired&quot;.[/note][/li]&#xA;[/randomList]&#xA;Core characterizations for the PropertyType value(s) attribute(s) include:[randomList]&#xA;[li]valueDetermination, that qualifies the method by which the value of the property has been determined[/li]&#xA;[li]valueRecordingDateTime, which identifies the calendar date and time when the property value was established[/li]&#xA;[/randomList]"/><Column name="ea_guid" value="{3FA38DD0-1E34-47bb-B57A-5A1E1DDC0BF0}"/><Extension Object_ID="{6A86C9A5-5B4D-46eb-B991-48A68729948A}"/></Row><Row><Column name="PropertyID" value="2049"/><Column name="Object_ID" value="32"/><Column name="Property" value="longDescription"/><Column name="Value" value="DateType Primitive"/><Column name="Notes" value="[referTo/]"/><Column name="ea_guid" value="{BFC04A04-A48B-46f3-8E76-02EF1D546A45}"/><Extension Object_ID="{6A86C9A5-5B4D-46eb-B991-48A68729948A}"/></Row><Row><Column name="PropertyID" value="2050"/><Column name="Object_ID" value="32"/><Column name="Property" value="longDescription"/><Column name="Value" value="StateType Primitive"/><Column name="Notes" value="Core characterizations for the StateType ([referTo/]) state attribute include stateRecordingDateTime, which identifies the calendar date and time when the state was established."/><Column name="ea_guid" value="{20E76463-B20B-40a5-A094-0AE7F1C0810E}"/><Extension Object_ID="{6A86C9A5-5B4D-46eb-B991-48A68729948A}"/></Row><Row><Column name="PropertyID" value="2051"/><Column name="Object_ID" value="32"/><Column name="Property" value="longDescription"/><Column name="Value" value="S-Series_UML_Primitives_001-00"/><Column name="Notes" value="UML primitives are S-Series IPS specification's UML representations of core UML primitives. The rationale for defining S-Series IPS specifications specific &lt;&lt;umlPrimitive&gt;&gt; representations for the respective UML primitive, is to enable additional characterizations to be applied to each individual UML primitive, and to enable its use in instances of ProjectSpecificAttribute. [referTo/].&#xA;The following UML primitives have a corresponding &lt;&lt;umlPrimitive&gt;&gt;[randomList]&#xA;[li]Boolean[/li]&#xA;[li]Integer[/li]&#xA;[li]String[/li]&#xA;[li]Real[/li]&#xA;[li]Unlimited natural[/li][/randomList]"/><Column name="ea_guid" value="{A128038F-CC72-4935-9EF7-AA8A7669AD8B}"/><Extension Object_ID="{6A86C9A5-5B4D-46eb-B991-48A68729948A}"/></Row><Row><Column name="PropertyID" value="2052"/><Column name="Object_ID" value="32"/><Column name="Property" value="longDescription"/><Column name="Value" value="S-Series_Primitives_003-00"/><Column name="ea_guid" value="{BD3FDC08-E163-4d44-99C2-987D1E74242E}"/><Extension Object_ID="{6A86C9A5-5B4D-46eb-B991-48A68729948A}"/></Row><Row><Column name="PropertyID" value="2053"/><Column name="Object_ID" value="43"/><Column name="Property" value="longDescription"/><Column name="Value" value="Compound Attributes"/><Column name="Notes" value="The S-Series IPS specifications compound attributes ([referTo/]) are:[randomList]&#xA;[li]AuthorizedLife, represents the maximum usage limit and upon reaching this limit any further usage of the item must be re-authorized[/li]&#xA;[li]DatedClassification, represents a classification in conjunction with its recording date[/li]&#xA;[li]DateRange, specifies an interval of dates[/li]&#xA;[li]DateTimeRange, specifies an interval of date and times[/li]&#xA;[li]SerialNumberRange, specifies an interval of serialized items[/li]&#xA;[li]ThreeDimensional, represents spatial magnitudes. There are three defined specializations of the ThreeDimensional &lt;&lt;compoundAttribute&gt;&gt;:[randomList]&#xA;[li]Cylinder, represents a three-dimensional object with straight parallel sides and a circular section[/li]&#xA;[li]Cuboid, represents a three-dimensional object where all its faces are rectangles and all angles are right angles[/li]&#xA;[li]Sphere, represents a three-dimensional object where every point on its surface is equidistant from its center[/li]&#xA;[li]TimeStampedClassification, represents a classification in conjunction with its recording time stamp[/li][/randomList][/li]&#xA;[li]Area, represents the extent or measurement of a two-dimensional surface. There are three defined specializations of the Area &lt;&lt;compoundAttribute&gt;&gt;:[randomList]&#xA;[li]Circle, represents a geometrical round plane figure whose boundary (the circumference) consists of points equidistant from a fixed point (the center)[/li]&#xA;[li]Rectangle, represents a geometrical plane figure with four straight sides and four right angles, especially one with unequal adjacent sides, in contrast to a square[/li]&#xA;[li]Triangle, represents a geometrical plane figure with three straight sides and three angles[/li]&#xA;[/randomList][/li]&#xA;[/randomList]&#xA;"/><Column name="ea_guid" value="{EA95D040-202A-413d-827A-0EAC007AD333}"/><Extension Object_ID="{7BABD806-12BE-4b3c-8313-78203D7D9FE4}"/></Row><Row><Column name="PropertyID" value="2054"/><Column name="Object_ID" value="838"/><Column name="Property" value="longDescription"/><Column name="Value" value="S-Series Base Object Definition"/><Column name="Notes" value="Core characterizations of the BaseObject ([referTo/]), therefore of any UML class, include:[randomList]&#xA;[li]uid, which provides the capability to uniquely identify an instance of an UML class in the context of a specific exchange file (XML document)[/li]&#xA;[li]uri, which provides the capability to uniquely identify an instance of an UML class in the context of the World Wide Web[/li]&#xA;[li]crud, which identifies the change operation to a class instance represented in the exchange file. A change is always relative to the latest exchanged values for the class instance. Change operations include create, read (retrieve), update and delete.[/li][/randomList]&#xA;Project specific attributes provide the capability to extend any class with characteristics that are peculiar to a specific implementation.&#xA;[note]The definition and scope for a project specific attribute must be defined in a separate XML schema as part of the exchange definition.[/note]"/><Column name="ea_guid" value="{6F1BCF14-BEAD-4d81-AB50-AA94ED8430F4}"/><Extension Object_ID="{2D4E0769-DF45-4c25-92BD-862DF8C98641}"/></Row><Row><Column name="PropertyID" value="2060"/><Column name="Object_ID" value="1718"/><Column name="Property" value="ICN"/><Column name="Value" value="S2000M Compound Attributes"/><Column name="Notes" value="ICN-B6865-S2000M0040-002-01"/><Column name="ea_guid" value="{70D21A33-BADB-4e2e-89D5-D07C02F446B5}"/><Extension Object_ID="{5B92EFDF-DA60-4abd-BF0F-60FD0511CAE2}"/></Row><Row><Column name="PropertyID" value="2157"/><Column name="Object_ID" value="1764"/><Column name="Property" value="xmlName"/><Column name="Value" value="curExc"/><Column name="ea_guid" value="{722EA2C0-B9D7-485a-A5DB-D70E137C78E8}"/><Extension Object_ID="{2314C845-89D5-473f-9849-7C3CDAF9CD24}"/></Row><Row><Column name="PropertyID" value="2158"/><Column name="Object_ID" value="1764"/><Column name="Property" value="xmlRefname"/><Column name="Value" value="curExcRef"/><Column name="ea_guid" value="{9E4585C2-7397-4646-9870-BB398B1AD0DA}"/><Extension Object_ID="{2314C845-89D5-473f-9849-7C3CDAF9CD24}"/></Row><Row><Column name="PropertyID" val