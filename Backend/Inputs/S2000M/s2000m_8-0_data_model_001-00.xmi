y the NCB."/><Column name="Derived" value="0"/><Column name="ID" value="1389"/><Column name="Pos" value="8"/><Column name="Length" value="0"/><Column name="Precision" value="0"/><Column name="Scale" value="0"/><Column name="Const" value="0"/><Column name="Style" value="SAD"/><Column name="Classifier" value="34"/><Column name="Type" value="DateType"/><Column name="ea_guid" value="{A254E957-B4E7-4815-A746-0C33190A6FDD}"/><Column name="StyleEx" value="IsLiteral=0;volatile=0;"/><Extension Object_ID="{929AF795-2880-412c-BF20-61198DD961C5}" Classifier="{7A76633A-B2FD-4016-A868-B6296518C883}"/></Row><Row><Column name="Object_ID" value="1855"/><Column name="Name" value="codificationEntryNatoStockNumberLastChangeDate"/><Column name="Scope" value="Public"/><Column name="Stereotype" value="characteristic"/><Column name="Containment" value="Not Specified"/><Column name="IsStatic" value="0"/><Column name="IsCollection" value="0"/><Column name="IsOrdered" value="0"/><Column name="AllowDuplicates" value="0"/><Column name="LowerBound" value="0"/><Column name="UpperBound" value="1"/><Column name="Notes" value="codificationEntryNatoStockNumberLastChangeDate is the date and time when the last change occurred on the NATO stock number data record."/><Column name="Derived" value="0"/><Column name="ID" value="1390"/><Column name="Pos" value="9"/><Column name="Length" value="0"/><Column name="Precision" value="0"/><Column name="Scale" value="0"/><Column name="Const" value="0"/><Column name="Style" value="SCD"/><Column name="Classifier" value="0"/><Column name="Type" value="DateType"/><Column name="ea_guid" value="{8E3EE1C0-1199-4f27-8730-BBDED89ADCF4}"/><Column name="StyleEx" value="IsLiteral=0;volatile=0;"/><Extension Object_ID="{929AF795-2880-412c-BF20-61198DD961C5}"/></Row><Row><Column name="Object_ID" value="1855"/><Column name="Name" value="codificationEntryNatoStockNumberStatus"/><Column name="Scope" value="Public"/><Column name="Stereotype" value="characteristic"/><Column name="Cont