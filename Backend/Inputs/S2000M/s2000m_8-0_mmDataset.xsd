			<xsd:element name="codId" type="codificationIdentifier"/>
			<xsd:element name="codificationRevId" type="codificationRevisionIdentifier"/>
			<xsd:element name="entryId" type="codificationEntryIdentifier"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="codificationRevisionRef">
		<xsd:annotation>
			<xsd:documentation>
            CodificationRevision is [class] representing an iteration applied to a Codification.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:CodificationRevision</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="codId" type="codificationIdentifier"/>
			<xsd:element name="codificationRevId" type="codificationRevisionIdentifier"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="contractRef">
		<xsd:annotation>
			<xsd:documentation>
            Contract is a [class] that represents a binding agreement between two or more parties.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:Contract</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="contrId" type="contractIdentifier"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="contractPartyRef">
		<xsd:annotation>
			<xsd:documentation>
