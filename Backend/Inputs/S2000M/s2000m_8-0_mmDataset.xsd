	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="party">
		<xsd:annotation>
			<xsd:documentation>
            Party is a [select] interface that identifies an entity that is capable of signing a contract or carrying out actions by itself without being instructed to 
            do so.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:Party</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:choice>
			<xsd:element name="orgRef" type="organizationRef"/>
		</xsd:choice>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:group name="projectSpecificAttributeValue">
		<xsd:annotation>
			<xsd:documentation>
            ProjectSpecificAttributeValue is a [select] interface that allows to associate an attribute type to a ProjectSpecificAttribute.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:ProjectSpecificAttributeValue</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:choice>
			<xsd:element name="opAul" type="authorizedLife"/>
			<xsd:element name="classifType" type="classificationType"/>
			<xsd:element name="dateRange" type="dateRange"/>
			<xsd:element name="dateTimeRange" type="dateTimeRange"/>
			<xsd:element name="dateTimeType" type="dateTimeType"/>
			<xsd:element name="dateType" type="dateType"/>
			<xsd:element name="descrType" type="descriptorType"/>
			<xsd:group ref="dimensionsNonAbstractClasses"/>
			<xsd:element name="idType" type="identifierType"/>
			<xsd:element name="nameType" type="nameType"/>
			<xsd:group ref="propertyTypeNonAbstractClasses"/>
			<xsd:element name="serNrRange" type="serialNumberRange"/>
			<xsd:element name="stateType" type="stateType"/>
			<xsd:element name="timeType" type="timeType"/>
			<xsd:element name="umlBool" type="umlBoolean"/>
			<xsd:element name="umlInt" type="umlInteger"/>
			<xsd:element name="umlReal" type="umlReal"/>
			<xsd:element name="umlStr" type="umlString"/>
			<xsd:element name="umlUnltd" type="umlUnlimitedNatural"/>
		</xsd:choice>
	</xsd:group>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="realizedPart">
		<xsd:annotation>
			<xsd:documentation>
            RealizedPart is a [select] interface that identifies which items can be used as an InstalledPart.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:RealizedPart</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:choice>
			<xsd:element name="partRef" type="partDefinitionRef"/>
			<xsd:element name="serialPartRef" type="serializedHardwarePartRef"/>
		</xsd:choice>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="referencedItem">
		<xsd:annotation>
			<xsd:documentation>
            ReferencedItem is an [select] interface that identifies items which can be selected as an allowed item referenced in a figure.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:ReferencedItem</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:choice>
			<xsd:element name="casRef" type="figureRef"/>
			<xsd:element name="figItemRef" type="figureItemRef"/>
			<xsd:element name="itemRealRef" type="figureItemRealizationRef"/>
			<xsd:element name="partRef" type="partDefinitionRef"/>
			<xsd:element name="ippnRef" type="provisioningDataPresentationRef"/>
		</xsd:choice>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="serializedAssertItem">
		<xsd:annotation>
			<xsd:documentation>
            SerializedAssertItem is a [select] interface that identifies classes from which an instance can be used as the EvaluationByAssertionOfSerializedItems 
            assert item.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:SerializedAssertItem</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:choice>
			<xsd:element name="partRef" type="partDefinitionRef"/>
			<xsd:element name="prodRef" type="productRef"/>
			<xsd:element name="prodVarRef" type="productVariantRef"/>
		</xsd:choice>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="statusAdvisoryItem">
		<xsd:annotation>
			<xsd:documentation>
            StatusAdvisoryItem is a [select] interface that provides information and/or observations about the status of a specific revision or entry of a Material 
            Supply list: Spare Parts, Quotation (Pricing), Ordering, Invoicing, Payment, Shipment or associated Del
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:StatusAdvisoryItem</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:choice>
			<xsd:element name="deliveryRef" type="deliveryRef"/>
			<xsd:element name="invoiceEntryRef" type="invoiceEntryRef"/>
			<xsd:element name="invoiceRevRef" type="invoiceRevisionRef"/>
			<xsd:element name="orderEntryRef" type="orderEntryRef"/>
			<xsd:element name="orderRevRef" type="orderRevisionRef"/>
			<xsd:element name="paymentEntryRef" type="paymentEntryRef"/>
			<xsd:element name="paymentRevRef" type="paymentRevisionRef"/>
			<xsd:element name="quotEntryRef" type="quotationEntryRef"/>
			<xsd:element name="quotRevRef" type="quotationRevisionRef"/>
			<xsd:element name="shipEntryRef" type="shipmentEntryRef"/>
			<xsd:element name="shipRevRef" type="shipmentRevisionRef"/>
			<xsd:element name="splEntryRef" type="sparePartsListEntryRef"/>
			<xsd:element name="splRevRef" type="sparePartsListRevisionRef"/>
		</xsd:choice>
	</xsd:complexType>
	<!-- ======================== UML <<EXTEND>> INTERFACE REFERENCE UTILITY CLASSES ======================== -->
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="applicabilityStatementItem">
		<xsd:annotation>
			<xsd:documentation>
            ApplicabilityStatementItem is an [extend] interface that provides its associated data model to those classes which can have restricted validity as defined 
            by an associated ApplicabilityStatement. 
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:ApplicabilityStatementItem</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence>
			<!-- UML-EmbeddedAssociations -->
			<xsd:element name="applicDefRef" type="applicabilityStatementRef" minOccurs="0"/>
		</xsd:sequence>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="businessAvailabilityItem">
		<xsd:annotation>
			<xsd:documentation>
            BusinessAvailabilityItem is an [extend] interface that provides its associated data model to those classes that can have an associated BusinessAvailability.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:BusinessAvailabilityItem</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence>
			<!-- UML-CompositionRelationships -->
			<xsd:element name="bsnssAvail" type="businessAvailability" nillable="true" minOccurs="0" maxOccurs="unbounded"/>
		</xsd:sequence>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="changeControlledItem">
		<xsd:annotation>
			<xsd:documentation>
            ChangeControlledItem is an [extend] interface that provides its associated data model to those classes that can be affected by a ChangeAuthorization.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:ChangeControlledItem</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence>
			<!-- UML-EmbeddedAssociations -->
			<xsd:element name="chg" type="changeNotification" nillable="true" minOccurs="0" maxOccurs="unbounded"/>
		</xsd:sequence>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="deliveryConditionItem">
		<xsd:annotation>
			<xsd:documentation>
            DeliveryConditionItem is a [extend] interface that provides additional information about the delivery condition (INCOTERMS).
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:DeliveryConditionItem</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence>
			<!-- UML-AttributeGroups -->
			<xsd:element name="delCond" type="deliveryCondition" nillable="true" minOccurs="0"/>
		</xsd:sequence>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="digitalFileReferencingItem">
		<xsd:annotation>
			<xsd:documentation>
            DigitalFileReferencingItem is an [extend] interface that provides its associated data model to those classes that implement it.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:DigitalFileReferencingItem</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence>
			<!-- UML-EmbeddedAssociations -->
			<xsd:element name="refFile" type="referencedDigitalFile" nillable="true" minOccurs="0" maxOccurs="unbounded"/>
		</xsd:sequence>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="documentReferencingItem">
		<xsd:annotation>
			<xsd:documentation>
            DocumentReferencingItem is an [extend] interface that provides its associated data model to those classes that implement it.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:DocumentReferencingItem</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence>
			<!-- UML-EmbeddedAssociations -->
			<xsd:element name="refDoc" type="referencedDocument" nillable="true" minOccurs="0" maxOccurs="unbounded"/>
		</xsd:sequence>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="installedPartItem">
		<xsd:annotation>
			<xsd:documentation>
            InstalledPartItem is an [extend] interface that provides its associated data model to those classes that implement it. 
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:InstalledPartItem</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence>
			<!-- UML-CompositionRelationships -->
			<xsd:element name="instPart" type="installedPart" nillable="true" minOccurs="0" maxOccurs="unbounded"/>
		</xsd:sequence>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="location">
		<xsd:annotation>
			<xsd:documentation>
            Location is an [extend] interface that provides its associated data model to those classes that implement it.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:Location</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence>
			<!-- UML-EmbeddedAssociations -->
			<xsd:element name="locRel" type="locationRelationship" nillable="true" minOccurs="0" maxOccurs="unbounded"/>
		</xsd:sequence>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="partyItem">
		<xsd:annotation>
			<xsd:documentation>
            PartyItem is an [extend] interface that enables the association of additional party related information to an Organization or a Person.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:PartyItem</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence>
			<!-- UML-EmbeddedAssociations -->
			<xsd:element name="ptyAddr" type="partyAddress" nillable="true" minOccurs="0" maxOccurs="unbounded"/>
			<xsd:element name="ptyRel" type="partyRelationship" nillable="true" minOccurs="0" maxOccurs="unbounded"/>
			<xsd:element name="cbuRef" type="bankDetailsRef" minOccurs="0" maxOccurs="unbounded"/>
		</xsd:sequence>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="projectSpecificExtensionItem">
		<xsd:annotation>
			<xsd:documentation>
            ProjectSpecificExtensionItem is an [extend] interface that allows to associate one or several instances of ProjectSpecificAttributes to any [class] or 
            [relationship] defined in the UML model.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:ProjectSpecificExtensionItem</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence>
			<!-- UML-CompositionRelationships -->
			<xsd:element name="projAttr" type="projectSpecificAttribute" nillable="true" minOccurs="0" maxOccurs="unbounded"/>
		</xsd:sequence>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="quotationTimingItem">
		<xsd:annotation>
			<xsd:documentation>
            QuotationTimingItem is an [extend] interface that provides a valid period of time during which the Quotation is valid.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:QuotationTimingItem</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence>
			<!-- UML-AttributeGroups -->
			<xsd:element name="quotTime" type="quotationTiming" nillable="true" minOccurs="0"/>
		</xsd:sequence>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="remarkItem">
		<xsd:annotation>
			<xsd:documentation>
            RemarkItem is an [extend] interface that provides its associated data model to those classes that implement it.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:RemarkItem</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence>
			<!-- UML-AttributeGroups -->
			<xsd:element name="rmk" type="remark" nillable="true" minOccurs="0" maxOccurs="unbounded"/>
		</xsd:sequence>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="securityClassificationItem">
		<xsd:annotation>
			<xsd:documentation>
            SecurityClassificationItem is an [extend] interface that provides its associated data model to those classes that implement it.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:SecurityClassificationItem</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence>
			<!-- UML-EmbeddedAssociations -->
			<xsd:element name="sec" type="securityClassification" nillable="true" minOccurs="0" maxOccurs="unbounded"/>
		</xsd:sequence>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="timeOffsetItem">
		<xsd:annotation>
			<xsd:documentation>
            TimeOffsetItem is an [extend] interface that provides its associated data model to those classes that implement it.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:TimeOffsetItem</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence>
			<!-- UML-AttributeGroups -->
			<xsd:element name="offset" type="timeOffset" nillable="true" minOccurs="0"/>
		</xsd:sequence>
	</xsd:complexType>
	<!-- ============================== UML SPECIALIZATION UTILITY CLASSES ================================== -->
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:group name="dimensionsNonAbstractClasses">
		<xsd:annotation>
			<xsd:documentation>
            Dimensions is a [compoundAttribute] that represents a set of values that define the measurable extent of a particular kind for a specific item.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:Dimensions</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:choice>
			<xsd:group ref="threeDimensionalNonAbstractClasses"/>
		</xsd:choice>
	</xsd:group>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:group name="evaluationCriteriaNonAbstractClasses">
		<xsd:annotation>
			<xsd:documentation>
            EvaluationCriteria is a [class] that defines conditions that can be mapped to a Boolean expression which can be evaluated to be either TRUE or FALSE.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:EvaluationCriteria</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:choice>
			<xsd:element name="assrtInst" type="evaluationByAssertionOfClassInstance"/>
			<xsd:element name="assrtSi" type="evaluationByAssertionOfSerializedItems"/>
			<xsd:element name="nestedApplic" type="evaluationByNestedApplicabilityStatement"/>
			<xsd:element name="evalAnd" type="logicalAnd"/>
			<xsd:element name="evalNot" type="logicalNot"/>
			<xsd:element name="evalOr" type="logicalOr"/>
		</xsd:choice>
	</xsd:group>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:group name="figureItemNonAbstractClasses">
		<xsd:annotation>
			<xsd:documentation>
            FigureItem is a [class] that identifies a specific location within the provisioning hierarchical breakdown in the context of a figure and its illustrations.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:FigureItem</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:choice>
			<xsd:element name="figCsn" type="actualFigureItem"/>
			<xsd:element name="headCsn" type="headerFigureItem"/>
		</xsd:choice>
	</xsd:group>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:group name="figureItemRealizationNonAbstractClasses">
		<xsd:annotation>
			<xsd:documentation>
            FigureItemRealization is a [class] that defines a specific part for a location within the provisioning breakdown in the context of a figure and its 
            illustrations.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:FigureItemRealization</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:choice>
			<xsd:element name="realPart" type="figureItemPartRealization"/>
			<xsd:element name="realSmf" type="figureItemSelectOrManufactureFrom"/>
		</xsd:choice>
	</xsd:group>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:group name="numericalPropertyTypeNonAbstractClasses">
		<xsd:annotation>
			<xsd:documentation>
            NumericalPropertyType is a PropertyType that represents a quantity by its numerical value together with the unit in which the value is given.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:NumericalPropertyType</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:choice>
			<xsd:element name="valuePrpType" type="singleValuePropertyType"/>
			<xsd:element name="rangePrpType" type="valueRangePropertyType"/>
			<xsd:element name="tolcePrpType" type="valueWithTolerancesPropertyType"/>
		</xsd:choice>
	</xsd:group>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:group name="partDefinitionNonAbstractClasses">
		<xsd:annotation>
			<xsd:documentation>
            PartDefinition is a [class] that represents the definitional information for an artifact fulfilling a set of requirements, which can be produced or 
            realized.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:PartDefinition</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:choice>
			<xsd:element name="hwPart" type="hardwarePartDefinition"/>
		</xsd:choice>
	</xsd:group>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:group name="propertyTypeNonAbstractClasses">
		<xsd:annotation>
			<xsd:documentation>
            PropertyType is an S-Series IPS specifications defined [primitive] that represents a measurable characteristic.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:PropertyType</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:choice>
			<xsd:group ref="numericalPropertyTypeNonAbstractClasses"/>
			<xsd:element name="txtPrpType" type="textPropertyType"/>
		</xsd:choice>
	</xsd:group>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:group name="threeDimensionalNonAbstractClasses">
		<xsd:annotation>
			<xsd:documentation>
            ThreeDimensional is a specialization of Dimensions that represents three dimensional spatial magnitudes.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:ThreeDimensional</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:choice>
			<xsd:element name="cuboid" type="cuboid"/>
			<xsd:element name="cylinder" type="cylinder"/>
			<xsd:element name="sphere" type="sphere"/>
		</xsd:choice>
	</xsd:group>
	<!-- ===================================== BASE SCHEMA DEFINITIONS ====================================== -->
	<xsd:simpleType name="uidRef">
		<xsd:restriction base="xsd:IDREF"/>
	</xsd:simpleType>
	<xsd:simpleType name="nonEmptyString">
		<xsd:restriction base="xsd:token">
			<xsd:minLength value="1"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="crudCode">
		<xsd:restriction base="xsd:string">
			<xsd:enumeration value="I">
				<xsd:annotation>
					<xsd:appinfo>
						<source>SX001G:insertedElement</source>
					</xsd:appinfo>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="D">
				<xsd:annotation>
					<xsd:appinfo>
						<source>SX001G:deletedElement</source>
					</xsd:appinfo>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="U">
				<xsd:annotation>
					<xsd:appinfo>
						<source>SX001G:updatedElement</source>
					</xsd:appinfo>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="R">
				<xsd:annotation>
					<xsd:appinfo>
						<source>SX001G:replacedElement</source>
					</xsd:appinfo>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="N">
				<xsd:annotation>
					<xsd:appinfo>
						<source>SX001G:nonChangedElement</source>
					</xsd:appinfo>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
</xsd:schema>