				<xsd:element name="partRef" type="partDefinitionRef"/>
				<xsd:element name="prcRef" type="partInProvisioningProjectRef"/>
				<xsd:element name="partReqDefRef" type="partRequirementsDefinitionRef"/>
				<xsd:element name="partServRef" type="partServiceRef"/>
