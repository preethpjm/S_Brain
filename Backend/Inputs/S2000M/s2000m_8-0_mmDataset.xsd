				<source>SX001G:StandardBusinessAvailability</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:choice>
				<xsd:element name="orgRef" type="organizationRef"/>
				<xsd:element name="ptyAddrRef" type="partyAddressRef"/>
			</xsd:choice>
			<xsd:element name="availType" type="businessAvailabilityType"/>
			<xsd:element name="availDay" type="standardBusinessAvailabilityDay"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="statusAdvisoryRef">
		<xsd:annotation>
			<xsd:documentation>
            StatusAdvisory is a [class] that provides a specific information and/or an observation about the status of a specific revision or entry of a Material 
            Supply list object.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:StatusAdvisory</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="statAdvId" type="statusAdviceIdentifier"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="streetAddressRef">
		<xsd:annotation>
			<xsd:documentation>
            StreetAddress is a [class&gt; that represents a locatable position along a road. 
         </xsd:documentation>
