			<xsd:element name="sPListRevId" type="sparePartsListRevisionIdentifier"/>
			<xsd:element name="sPListEntId" type="sparePartsListEntryIdentifier"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="sparePartsListRevisionRef">
		<xsd:annotation>
			<xsd:documentation>
            SparePartsListRevision is [class] representing an iteration applied to a SparePartsList.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:SparePartsListRevision</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="splId" type="sparePartsListIdentifier"/>
			<xsd:element name="sPListRevId" type="sparePartsListRevisionIdentifier"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="specialBusinessAvailabilityRef">
		<xsd:annotation>
			<xsd:documentation>
            SpecialBusinessAvailability is a [class] that represents business availability hours which is specific to a given period and deviates from the 
            StandardBusinessAvailability.
         </xsd:documentation>
