			<xsd:element name="scn" type="shipmentConsignmentNumber"/>
			<xsd:element name="shipmentRevId" type="shipmentRevisionIdentifier"/>
			<xsd:element name="shipmentEntId" type="shipmentEntryIdentifier"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="shipmentPartyRef">
		<xsd:annotation>
			<xsd:documentation>
            ShipmentParty is a [relationship] between a Shipment and a stakeholder for the Shipment.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:ShipmentParty</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="shipRevRef" type="shipmentRevisionRef"/>
			<xsd:element name="shipPtyRef" type="shipmentPartyRef"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="shipmentRevisionRef">
		<xsd:annotation>
			<xsd:documentation>
            ShipmentRevision is [class] representing an iteration applied to a Shipment.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:ShipmentRevision</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="scn" type="shipmentConsignmentNumber"/>
			<xsd:element name="shipmentRevId" type="shipmentRevisionIdentifier"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="sparePartsListRef">
		<xsd:annotation>
			<xsd:documentation>
            SparePartsList is a [class] that provides a set of parts data for material management and procurement for projects without the need of the full Initial 
            Provisioning.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:SparePartsList</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="splId" type="sparePartsListIdentifier"/>
		</xsd:sequence>
