			<xsd:element name="pos" type="partOverhaulabilityStrategy" minOccurs="0" nillable="true"/>
			<xsd:element name="prs" type="partRecoverabilityStrategy" minOccurs="0" nillable="true"/>
			<xsd:element name="pnc" type="partNationalSpecificClassification" minOccurs="0" nillable="true"/>
		</xsd:sequence>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="hardwarePartDefinitionDesignData">
		<xsd:annotation>
			<xsd:documentation>
            HardwarePartDefinitionDesignData is an [attributeGroup] that establishes characteristics of part, that are typically defined during its design.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:HardwarePartDefinitionDesignData</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence>
			<!-- UML-Attributes -->
			<xsd:element name="haz" type="hardwarePartHazardousClass" minOccurs="0" maxOccurs="unbounded" nillable="true"/>
			<xsd:element name="ftc" type="hardwarePartFitmentRequirement" minOccurs="0" nillable="true"/>
			<xsd:element name="emi" type="hardwarePartElectromagneticIncompatible" minOccurs="0" nillable="true"/>
			<xsd:element name="ess" type="hardwarePartElectrostaticSensitive" minOccurs="0" nillable="true"/>
			<xsd:element name="ems" type="hardwarePartElectromagneticSensitive" minOccurs="0" nillable="true"/>
			<xsd:element name="mse" type="hardwarePartMagneticSensitive" minOccurs="0" nillable="true"/>
			<xsd:element name="rse" type="hardwarePartRadiationSensitive" minOccurs="0" nillable="true"/>
			<xsd:element name="suu" type="hardwarePartSize" minOccurs="0" nillable="true"/>
			<xsd:element name="wuu" type="hardwarePartMass" minOccurs="0" nillable="true"/>
			<xsd:element name="sim" type="serializedItemTraceabilityRequirement" minOccurs="0" nillable="true"/>
			<xsd:element name="cmk" type="hardwarePartCalibrationRequirement" minOccurs="0" nillable="true"/>
			<xsd:element name="str" type="hardwarePartSpecialStorageRequirement" minOccurs="0" nillable="true"/>
			<xsd:element name="opAul" type="hardwarePartOperationalAuthorizedLife" minOccurs="0" maxOccurs="unbounded" nillable="true"/>
			<xsd:element name="slm" type="hardwarePartShelfLifeLimit" minOccurs="0" nillable="true"/>
			<xsd:element name="slt" type="hardwarePartShelfLifeType" minOccurs="0" nillable="true"/>
			<xsd:element name="sla" type="hardwarePartShelfLifeLimitAction" minOccurs="0" nillable="true"/>
			<xsd:element name="tlf" type="hardwarePartTotalLifeLimit" minOccurs="0" maxOccurs="unbounded" nillable="true"/>
		</xsd:sequence>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="sparesRecommendation">
		<xsd:annotation>
			<xsd:documentation>
            SparesRecommendation is an [attributeGroup] that collects information of Spare Parts Recommendations for a given Applicability.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:SparesRecommendation</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence>
			<!-- UML-Attributes -->
			<xsd:element name="rsq" type="recommendedSparesQuantity" minOccurs="0" nillable="true"/>
			<!-- UML-Extends -->
			<xsd:element name="applic" type="applicabilityStatementItem" nillable="true" minOccurs="0"/>
		</xsd:sequence>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="quotationTiming">
		<xsd:annotation>
			<xsd:documentation>
            QuotationTiming is a [class] that represents the date range whithin which the Quotation is valid.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:QuotationTiming</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence>
			<!-- UML-Attributes -->
			<xsd:element name="qfd" type="quotationEffectiveDate" minOccurs="0" nillable="true"/>
			<xsd:element name="qed" type="quotationExpiryDate" minOccurs="0" nillable="true"/>
		</xsd:sequence>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="messageControlData">
		<xsd:annotation>
			<xsd:documentation>
            MessageControlData is an [attributeGroup] that establish if it's required and when an acknowledgement response for the message.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:MessageControlData</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence>
			<!-- UML-Attributes -->
			<xsd:element name="ackReq" type="acknowledgementRequired" minOccurs="0" nillable="true"/>
			<xsd:element name="ppt" type="priorityProcessingTime" minOccurs="0" nillable="true"/>
		</xsd:sequence>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="messageControlError">
		<xsd:annotation>
			<xsd:documentation>
            MessageControlError is an [attributeGroup] that provides detailed information about the error detected in the related message.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:MessageControlError</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence>
			<!-- UML-Attributes -->
			<xsd:element name="msgCntrlErrCode" type="messageControlErrorCode" minOccurs="0" nillable="true"/>
			<xsd:element name="msgCntrlErrLoc" type="messageControlErrorLocation" minOccurs="0" nillable="true"/>
			<xsd:element name="msgCntrlErrDes" type="messageControErrorDescription" minOccurs="0" maxOccurs="unbounded" nillable="true"/>
		</xsd:sequence>
	</xsd:complexType>
	<!-- =============================== UML CLASS REFERENCE UTILITY CLASSES ================================ -->
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="actualFigureItemRef">
		<xsd:annotation>
			<xsd:documentation>
            ActualFigureItem is a [class] that identifies whether the item at the location is included in the illustration and if the item is attaching, storage or 
            shipping item.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:ActualFigureItem</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="figId" type="figureIdentifier"/>
			<xsd:element name="csn" type="figureItemIdentifier"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="alternatePartDefinitionRef">
		<xsd:annotation>
			<xsd:documentation>
            AlternatePartDefinition is a [relationship] that defines an alternate PartDefinition which can replace the base PartDefinition in all its usages ie, it is 
            context independent, and is form, fit, and function equivalent.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:AlternatePartDefinition</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<!-- RELATING -->
			<xsd:element name="partRef" type="partDefinitionRef"/>
			<!-- RELATED -->
			<xsd:element name="altPartRef" type="alternatePartDefinitionRef"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="applicabilityStatementRef">
		<xsd:annotation>
			<xsd:documentation>
            ApplicabilityStatement is a [class] that defines the situation or situations under which related items are valid.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:ApplicabilityStatement</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="applicId" type="applicabilityStatementIdentifier"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="bankDetailsRef">
		<xsd:annotation>
			<xsd:documentation>
            BankDetails is a [class] to contain the complete reference of the bank of the contractor to be used for payment.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:BankDetails</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="cbc" type="bankCode"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="businessAvailabilityRef">
		<xsd:annotation>
			<xsd:documentation>
            BusinessAvailability is a [class] that represents the collection of days and hours when the related BusinessAvailability is accessible.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:BusinessAvailability</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:choice>
				<xsd:element name="orgRef" type="organizationRef"/>
				<xsd:element name="ptyAddrRef" type="partyAddressRef"/>
			</xsd:choice>
			<xsd:element name="availType" type="businessAvailabilityType"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="caseRef">
		<xsd:annotation>
			<xsd:documentation>
            Case is a [class] that identifies each individual container of a handling unit.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:Case</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="cno" type="caseNumber"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="caseItemRef">
		<xsd:annotation>
			<xsd:documentation>
            CaseItem is a [relationship] between a case and its content.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:CaseItem</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="caseRef" type="caseRef"/>
			<xsd:element name="caseContentRef" type="caseItemRef"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="changeAuthorizationRef">
		<xsd:annotation>
			<xsd:documentation>
            ChangeAuthorization is a [class] that is the record of the permission to modify product design, its procedures and/or associated product support data.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:ChangeAuthorization</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="chgAuthId" type="changeAuthorizationIdentifier"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="changeNotificationRef">
		<xsd:annotation>
			<xsd:documentation>
            ChangeNotification is a [relationship] that identifies an item changed due to the associated ChangeAuthorization.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:ChangeNotification</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:choice>
				<xsd:element name="altPartRef" type="alternatePartDefinitionRef"/>
				<xsd:element name="docIssRef" type="documentIssueRef"/>
				<xsd:element name="itemModRef" type="figureItemModificationRef"/>
				<xsd:element name="itemRealRef" type="figureItemRealizationRef"/>
				<xsd:element name="illRef" type="illustrationRef"/>
				<xsd:element name="instPartRef" type="installedPartRef"/>
				<xsd:element name="pppDelRef" type="provisioningProgramPlanDeliveryRef"/>
				<xsd:element name="rppRef" type="replacementPartRelationshipRef"/>
				<xsd:element name="secRef" type="securityClassificationRef"/>
			</xsd:choice>
			<xsd:element name="chgRef" type="changeNotificationRef"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="codificationRef">
		<xsd:annotation>
			<xsd:documentation>
            Codification is a [class] that provides a list of Hardware Parts and their data related to NATO Codification.
