			<xsd:appinfo>
				<source>SX001G:DocumentIssue</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="docId" type="documentIdentifier"/>
			<xsd:element name="docIssId" type="documentIssueIdentifier"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="evaluationByAssertionOfClassInstanceRef">
		<xsd:annotation>
			<xsd:documentation>
            EvaluationByAssertionOfClassInstance is an EvaluationCriteria that identifies a class instance to be used as an assert item and be mapped to a Boolean 
            expression which can be evaluated to be either TRUE or FALSE.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:EvaluationByAssertionOfClassInstance</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="evaluationByAssertionOfSerializedItemsRef">
		<xsd:annotation>
			<xsd:documentation>
            EvaluationByAssertionOfSerializedItems is an EvaluationCriteria that identifies a class instance together with an associated serial number range to be used 
            as an assert item and be mapped to a Boolean expression which can be evaluated to be either TRUE or FALSE.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:EvaluationByAssertionOfSerializedItems</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="evaluationByNestedApplicabilityStatementRef">
		<xsd:annotation>
			<xsd:documentation>
            EvaluationByNestedApplicabilityStatement is an EvaluationCriteria that enables an ApplicabilityStatement to be reused as part of this EvaluationCriteria.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:EvaluationByNestedApplicabilityStatement</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="evaluationCriteriaRef">
		<xsd:annotation>
			<xsd:documentation>
            EvaluationCriteria is a [class] that defines conditions that can be mapped to a Boolean expression which can be evaluated to be either TRUE or FALSE.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:EvaluationCriteria</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="figureRef">
		<xsd:annotation>
			<xsd:documentation>
            Figure is a [class] that identifies a provisioning hierarchical breakdown of a product or portion of a product.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:Figure</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="figId" type="figureIdentifier"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="figureItemRef">
		<xsd:annotation>
			<xsd:documentation>
            FigureItem is a [class] that identifies a specific location within the provisioning hierarchical breakdown in the context of a figure and its illustrations.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:FigureItem</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="figId" type="figureIdentifier"/>
			<xsd:element name="csn" type="figureItemIdentifier"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="figureItemContainerLocationRef">
		<xsd:annotation>
			<xsd:documentation>
            FigureItemContainerLocation is a [class] that identifies the location at which the data record for the item's Category 1 Container is held.
            Enter the Item Number and Item Number Variant (part of the figureItemIdentifier) and the figureItemSequenceNumber of the Category 1 Container record. 
            The figureItemContainerLocation must be provided for those items for which a Category 1 Container is available/ required.
            The record for the Category 1 Container will be situated at indentureLevel 1 at the end of the figure containing the item.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:FigureItemContainerLocation</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="realPartRef" type="figureItemPartRealizationRef"/>
			<xsd:element name="ctlRef" type="figureItemContainerLocationRef"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="figureItemModificationRef">
		<xsd:annotation>
			<xsd:documentation>
            FigureItemModification is a [relationship] that groups information about modifications and amendments of a part at a given location.
            See changeAuthorityIdentifier.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:FigureItemModification</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<!-- RELATING -->
			<xsd:element name="itemRealRef" type="figureItemRealizationRef"/>
			<!-- RELATED -->
			<xsd:element name="itemModRef" type="figureItemModificationRef"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="figureItemPartRealizationRef">
		<xsd:annotation>
			<xsd:documentation>
            FigureItemPartRealization is a [class] that identifies the part used in the location. It can also include references to other locations where the breakdown 
            for the part is provided. Furthermore it can include references to container information for the part under consideration.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:FigureItemPartRealization</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="figId" type="figureIdentifier"/>
			<xsd:element name="csn" type="figureItemIdentifier"/>
			<xsd:element name="isn" type="figureItemSequenceNumber"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="figureItemRealizationRef">
		<xsd:annotation>
			<xsd:documentation>
            FigureItemRealization is a [class] that defines a specific part for a location within the provisioning breakdown in the context of a figure and its 
            illustrations.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:FigureItemRealization</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="figId" type="figureIdentifier"/>
			<xsd:element name="csn" type="figureItemIdentifier"/>
			<xsd:element name="isn" type="figureItemSequenceNumber"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="figureItemReferenceRef">
		<xsd:annotation>
			<xsd:documentation>
            FigureItemReference is a [relationship] that provides a two way link between the two locations that an item has when it appears in the breakdown of one 
            figure and is 'referred out' to a separate figure which is created to present the breakdown of that item. It also provides a one way link between an item, 
            in its position within the breakdown of its next higher assembly, and its own separate Provisioning presentation.
            When reference is made within the same Illustrated Parts Catalogue, enter the full figureItemIdentifier and figureItemSequenceNumber of the item's other 
            location.
            The Format is to be that defined for figureItemIdentifier and figureItemSequenceNumber.
            When a position of the figureItemIdentifier of the item's other location is blank then it shall also be blank in the FigureItemReference.
            When an item is 'referred out' to its own separate IP Project (ie it has a repairabilityStrategy of 6 then enter the ABBREVIATION 'IPP' followed by the 
            provisioningProjectIdentifier, instead of figureItemIdentifier and figureItemSequenceNumber. In this case the link will be just one way.
            When an item is 'referred out' to a Separate Equipment IPC (ie it has a repairabilityStrategy (SPC) of 6 and the Separate Equipment IPC is not to S2000M 
            Specification, then enter the ABBREVIATION "IPP" followed by "NON-ASD".
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:FigureItemReference</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="realPartRef" type="figureItemPartRealizationRef"/>
			<xsd:element name="rtxRef" type="figureItemReferenceRef"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="figureItemSelectOrManufactureFromRef">
		<xsd:annotation>
			<xsd:documentation>
            FigureItemSelectOrManufactureFrom is a [class] that provides a means to specify a part, which must be tested for fit or function, manufactured, re-worked 
            or repaired prior to installation.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:FigureItemSelectOrManufactureFrom</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="figId" type="figureIdentifier"/>
			<xsd:element name="csn" type="figureItemIdentifier"/>
			<xsd:element name="isn" type="figureItemSequenceNumber"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="geographicalAreaRef">
		<xsd:annotation>
			<xsd:documentation>
            GeographicalArea is a [class] that represents a particular extent of space.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:GeographicalArea</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="areaName" type="geographicalAreaName"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="globalPositionRef">
		<xsd:annotation>
			<xsd:documentation>
            GlobalPosition is a [class] that identifies a point in space by a set of coordinates.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:GlobalPosition</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="lat" type="latitude"/>
			<xsd:element name="long" type="longitude"/>
			<xsd:element name="alt" type="altitude"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="handlingUnitRef">
		<xsd:annotation>
			<xsd:documentation>
            HandlingUnit is a [class] that represents a physical unit consisting of packaging materials (load carriers/packing material) and the goods contained on/in 
            it. A handling unit is always a combination of products and packaging materials.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:HandlingUnit</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="hun" type="handlingUnitNumber"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="handlingUnitItemRef">
		<xsd:annotation>
			<xsd:documentation>
            HandlingUnitItem is a [relationship] between a handling unit and its content.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:HandlingUnitItem</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="hUnitRef" type="handlingUnitRef"/>
			<xsd:element name="hUnitContentRef" type="handlingUnitItemRef"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="hardwarePartDefinedContainerRef">
		<xsd:annotation>
			<xsd:documentation>
            HardwarePartDefinedContainer is a [relationship] that identifies a specialized, reusable container (also termed Category 1 Container) that has to be used 
            for shipping and storage for the part under consideration. The container is identified through its partIdentifier and partName.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:HardwarePartDefinedContainer</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<!-- RELATING -->
			<xsd:element name="hwPartRef" type="hardwarePartDefinitionRef"/>
			<!-- RELATED -->
			<xsd:element name="ctiRef" type="hardwarePartDefinedContainerRef"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="hardwarePartDefinitionRef">
		<xsd:annotation>
			<xsd:documentation>
            HardwarePartDefinition is a PartDefinition that is to be realized as physical items, including non-countable material.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:HardwarePartDefinition</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="partId" type="partIdentifier"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="hardwarePartDefinitionCommerceDataRef">
		<xsd:annotation>
			<xsd:documentation>
            HardwarePartDefinitionCommerceData is a [class] that documents pricing information of a part based on its units of issue. The prices are used for planning 
            purposes on customer side and reflect initial prices, provided by provisioning.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:HardwarePartDefinitionCommerceData</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="headerFigureItemRef">
		<xsd:annotation>
			<xsd:documentation>
            HeaderFigureItem is a [class] that establishes header information for location without an actual part associated to it (e.g. rivet figure, consumable 
            figure, raw material figure, etc.).
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:HeaderFigureItem</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="figId" type="figureIdentifier"/>
			<xsd:element name="csn" type="figureItemIdentifier"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="illustrationRef">
		<xsd:annotation>
			<xsd:documentation>
            Illustration is a [class] that establishes the graphical representation of a product or a portion of a product.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:Illustration</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="figId" type="figureIdentifier"/>
			<xsd:element name="icn" type="informationControlNumber"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="installedAtLocationRef">
		<xsd:annotation>
			<xsd:documentation>
            InstalledAtLocation is a [relationship] that represents a figure position within the associated SerializedProductVariant.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:InstalledAtLocation</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="serialPVRef" type="serializedProductVariantRef"/>
			<xsd:element name="instFigLocRef" type="installedAtLocationRef"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="installedPartRef">
		<xsd:annotation>
			<xsd:documentation>
            InstalledPart is a [class] that identifies a period during which a given RealizedPart is, or has been, installed at the InstallationLocation.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:InstalledPart</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:choice>
				<xsd:element name="instFigLocRef" type="installedAtLocationRef"/>
			</xsd:choice>
			<xsd:element name="instDate" type="installedDateTime"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="invoiceRef">
		<xsd:annotation>
			<xsd:documentation>
            Invoice is a [class] that covers the activities of the contractor and the customer to transmit/receive relevant and required information with regard to the 
            financial regulation for delivered items, tasks, services etc.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:Invoice</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="inr" type="invoiceIdentifier"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="invoiceEntryRef">
		<xsd:annotation>
			<xsd:documentation>
            InvoiceEntry is a [class] that represents the inclusion of a PartDefinition in an Invoice.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:InvoiceEntry</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="inr" type="invoiceIdentifier"/>
			<xsd:element name="invoiceRevId" type="invoiceRevisionIdentifier"/>
			<xsd:element name="invoiceEntId" type="invoiceEntryIdentifier"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="invoicePartyRef">
		<xsd:annotation>
			<xsd:documentation>
            InvoiceParty is a [relationship] between a Invoice and a stakeholder for the Invoice.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:InvoiceParty</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="invoiceRevRef" type="invoiceRevisionRef"/>
			<xsd:element name="invPtyRef" type="invoicePartyRef"/>
			<xsd:element name="invoicePartyType" type="invoicePartyType"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="invoiceRelationshipRef">
		<xsd:annotation>
			<xsd:documentation>
            InvoiceRelationship is a [relationship] where one Invoice relates to another Invoice.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:InvoiceRelationship</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<!-- RELATING -->
			<xsd:element name="invoiceRevRef" type="invoiceRevisionRef"/>
			<!-- RELATED -->
			<xsd:element name="invRelRef" type="invoiceRelationshipRef"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="invoiceRevisionRef">
		<xsd:annotation>
			<xsd:documentation>
            InvoiceRevision is [class] representing an iteration applied to a Invoice.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:InvoiceRevision</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="inr" type="invoiceIdentifier"/>
			<xsd:element name="invoiceRevId" type="invoiceRevisionIdentifier"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="locationRelationshipRef">
		<xsd:annotation>
			<xsd:documentation>
            LocationRelationship is a [relationship] where one LocationItem relates to another LocationItem
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:LocationRelationship</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:choice>
				<xsd:element name="countryRef" type="countryRef"/>
				<xsd:element name="geoAreaRef" type="geographicalAreaRef"/>
				<xsd:element name="globPosRef" type="globalPositionRef"/>
				<xsd:element name="strAddrRef" type="streetAddressRef"/>
			</xsd:choice>
			<xsd:element name="locRelRef" type="locationRelationshipRef"/>
			<xsd:element name="relType" type="locationRelationshipType"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="logicalAndRef">
		<xsd:annotation>
			<xsd:documentation>
            LogicalAnd is an EvaluationCriteria that defines a boolean operation where the results of all its associated EvaluationCriteria must be TRUE for the result 
            to be TRUE, otherwise the result is FALSE.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:LogicalAnd</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="logicalNotRef">
		<xsd:annotation>
			<xsd:documentation>
            LogicalNot is an EvaluationCriteria that defines a boolean operation where the result from its associated EvaluationCriteria must be FALSE for the result 
            to be TRUE, otherwise the result is FALSE.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:LogicalNot</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="logicalOrRef">
		<xsd:annotation>
			<xsd:documentation>
            LogicalOr is an EvaluationCriteria that defines a boolean operation where the result from at least one of its associated EvaluationCriteria must be TRUE 
            for the result to be TRUE, otherwise the result is FALSE.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:LogicalOr</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="maintenanceLevelRef">
		<xsd:annotation>
			<xsd:documentation>
            MaintenanceLevel is a [class] that represents the definition of a set of maintenance capabilities which will be made available to support a defined Product.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:MaintenanceLevel</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="mlvId" type="maintenanceLevelIdentifier"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="maintenanceSolutionAndSparesRecommendationRef">
		<xsd:annotation>
			<xsd:documentation>
            MaintenanceSolutionAndSparesRecommendation is a [class] that indicates percentage of unscheduled removals as well as recommended spares quantities.
            In case of add applicability, only Organization and/or Product/ProductVariant can be used as statement items.
            In case of use of Product/ProductVariant applicability, it must be a subset of the Product/ProductVariant of his parent class FigureItemRealization 
            applicability range.
            In case of Organizarion applicability, the evaluationByAssertionRole for Organization must be set to 'USER'.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:MaintenanceSolutionAndSparesRecommendation</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="messageRef">
		<xsd:annotation>
			<xsd:documentation>
            Message is a [class] that represents the collection of information brought together by a message sender for the purpose of communicating it to another 
            party.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:Message</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="msgId" type="messageIdentifier"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="messageContextRef">
		<xsd:annotation>
			<xsd:documentation>
            MessageContext is a [relationship] between a Message and the context for which it is being provided.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:MessageContext</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="msgRef" type="messageRef"/>
			<xsd:element name="msgContextRef" type="messageContextRef"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="messageControlResponseRef">
		<xsd:annotation>
			<xsd:documentation>
            MessageControlResponse is a [class] that provides information about the success or failure of system processing of the related message.
            This must be included in a message response if acknowledgment of receipt is required.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:MessageControlResponse</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="messagePartyRef">
		<xsd:annotation>
			<xsd:documentation>
            MessageParty is a [relationship] between a Message and a stakeholder for the Message.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:MessageParty</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="msgRef" type="messageRef"/>
			<xsd:element name="msgPtyRef" type="messagePartyRef"/>
			<xsd:element name="ptyType" type="messagePartyType"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="messageRelationshipRef">
		<xsd:annotation>
			<xsd:documentation>
            MessageRelationship is a [relationship] where one Message relates to another Message.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:MessageRelationship</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<!-- RELATING -->
			<xsd:element name="msgRef" type="messageRef"/>
			<!-- RELATED -->
			<xsd:element name="relatedMsgRef" type="messageRelationshipRef"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="observationRef">
		<xsd:annotation>
			<xsd:documentation>
            Observation is a [class] that defines a review on IP data which have been previously transmitted, and values for Customer provided data.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:Observation</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="osn" type="observationIdentifier"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="orderRef">
		<xsd:annotation>
			<xsd:documentation>
            Order is a [class] enables the customer to place and to progress orders for items and all types of services.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:Order</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="don" type="orderIdentifier"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="orderEntryRef">
		<xsd:annotation>
			<xsd:documentation>
            OrderEntry is a [class] that represents the inclusion of a PartDefinition in a Order.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:OrderEntry</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="don" type="orderIdentifier"/>
			<xsd:element name="orderRevId" type="orderRevisionIdentifier"/>
			<xsd:element name="orderEntId" type="orderEntryIdentifier"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="orderRevisionRef">
		<xsd:annotation>
			<xsd:documentation>
            OrderRevision is [class] representing an iteration applied to a Order.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:OrderRevision</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="don" type="orderIdentifier"/>
			<xsd:element name="orderRevId" type="orderRevisionIdentifier"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="organizationRef">
		<xsd:annotation>
			<xsd:documentation>
            Organization is a [class] that represents an administrative structure with a particular purpose belonging to a legal entity.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:Organization</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="orgId" type="organizationIdentifier"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="partDefinitionRef">
		<xsd:annotation>
			<xsd:documentation>
            PartDefinition is a [class] that represents the definitional information for an artifact fulfilling a set of requirements, which can be produced or 
            realized.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:PartDefinition</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="partId" type="partIdentifier"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="partInProvisioningProjectRef">
		<xsd:annotation>
			<xsd:documentation>
            PartInProvisioningProject is a [relationship] that defines a complete data set for Part Number-oriented presentation.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:PartInProvisioningProject</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="ippnRef" type="provisioningDataPresentationRef"/>
			<xsd:element name="prcRef" type="partInProvisioningProjectRef"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="partRequirementsDefinitionRef">
		<xsd:annotation>
			<xsd:documentation>
            PartRequirementsDefinition is a [class] that establishes a reference to a specific set of requirements, that the part fulfills.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:PartRequirementsDefinition</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="age" type="requirementsDefinitionNumber"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="partServiceRef">
		<xsd:annotation>
			<xsd:documentation>
            PartService is a [class] that defines the scope of the business related to a specific business process.
            The codes/values and their meaning need to be specified and agreed at the beginning of a Project.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:PartService</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="partServId" type="partServiceIdentifier"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="partyAddressRef">
		<xsd:annotation>
			<xsd:documentation>
            PartyAddress is a [relationship] that defines the association between a Party and an Address.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:PartyAddress</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:choice>
				<xsd:element name="orgRef" type="organizationRef"/>
			</xsd:choice>
			<xsd:element name="ptyAddrRef" type="partyAddressRef"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="partyRelationshipRef">
		<xsd:annotation>
			<xsd:documentation>
            PartyRelationship is a relationship where one Party relates to another Party.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:PartyRelationship</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:choice>
				<xsd:element name="orgRef" type="organizationRef"/>
			</xsd:choice>
			<xsd:element name="ptyRelRef" type="partyRelationshipRef"/>
			<xsd:element name="relType" type="partyRelationshipType"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="paymentRef">
		<xsd:annotation>
			<xsd:documentation>
            Payment is a [class] that provides the data related to settle the invoices.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:Payment</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="paymentId" type="paymentIdentifier"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="paymentEntryRef">
		<xsd:annotation>
			<xsd:documentation>
            PaymentEntry is a [class] that represents the inclusion of a PartDefinition in a Payment.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:PaymentEntry</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="paymentId" type="paymentIdentifier"/>
			<xsd:element name="paymentRevId" type="paymentRevisionIdentifier"/>
			<xsd:element name="paymentEntId" type="paymentEntryIdentifier"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="paymentPartyRef">
		<xsd:annotation>
			<xsd:documentation>
            PaymentParty is a [relationship] between a Payment and a stakeholder for the Payment.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:PaymentParty</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="paymentRevRef" type="paymentRevisionRef"/>
			<xsd:element name="payPtyRef" type="paymentPartyRef"/>
			<xsd:element name="paymentPartyType" type="paymentPartyType"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="paymentRevisionRef">
		<xsd:annotation>
			<xsd:documentation>
            PaymentRevision is [class] representing an iteration applied to a Payment.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:PaymentRevision</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="paymentId" type="paymentIdentifier"/>
			<xsd:element name="paymentRevId" type="paymentRevisionIdentifier"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="preAssessmentMeetingRef">
		<xsd:annotation>
			<xsd:documentation>
            PreAssessmentMeeting is a [class] that represents a meeting of IP specialists from industry and customer, and if required a representative from the Home 
            National Codification Bureau and/or the Original Equipment Manufacturer (OEM), at which the Initial Provisioning Lists and Illustrations are reviewed and 
            technical approval given by the customer.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:PreAssessmentMeeting</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="productRef">
		<xsd:annotation>
			<xsd:documentation>
            Product is a [class] that represents a family of items which share the same underlying design purpose.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:Product</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="prodId" type="productIdentifier"/>
		</xsd:sequence>
		<xsd:attribute name="uidRef" type="xsd:IDREF" use="optional"/>
		<xsd:attribute name="uriRef" type="xsd:anyURI" use="optional"/>
		<xsd:assert test="(@uidRef and not(@uriRef)) or (not(@uidRef) and @uriRef)"/>
	</xsd:complexType>
	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="productVariantRef">
		<xsd:annotation>
			<xsd:documentation>
            ProductVariant is a [class] that defines a member of a Product family which is configured for a specific purpose and is made available to the market.
         </xsd:documentation>
			<xsd:appinfo>
				<source>SX001G:ProductVariant</source>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:sequence minOccurs="0">
			<xsd:element name="prodId" type="productIdentifier"/>
			<xsd:element name="prodVarId" type="productVariantIdentifier"/>
