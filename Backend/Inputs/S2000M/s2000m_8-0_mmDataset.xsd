	<!-- ________________________________________________________________________________________________________________ -->
	<xsd:complexType name="standardBusinessAvailabilityRef">
		<xsd:annotation>
			<xsd:documentation>
            StandardBusinessAvailability is a [class] that represents regular business availability hours.
